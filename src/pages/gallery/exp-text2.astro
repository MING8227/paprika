---
import Base from '../../layouts/Base.astro';
---
<Base title="实验2: 双层粒子">
  <article>
    <h1>实验2: 双层粒子 · Two Hands</h1>
    <div class="article-content">
      <div id="exp-canvas" style="margin: 2rem 0; display: flex; justify-content: center;"></div>
      <p style="text-align: center; font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-muted);">
        同一段文字，两种存在。等它慢慢变。
      </p>
    </div>
  </article>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.4/p5.min.js"></script>
  <script is:inline>
  (function() {
    var W = 580, H = 700;
    var layerA = []; // familiar — warm, still
    var layerB = []; // strange — cool, drifting

    // Multiple lines of text
    var lines = ['yesterday', 'i wrote you', 'a letter', 'but the', 'handwriting', 'is not mine'];

    new p5(function(p) {
      p.setup = function() {
        var canvas = p.createCanvas(W, H);
        canvas.parent('exp-canvas');
        p.pixelDensity(1);
        buildLayers();
      };

      function buildLayers() {
        var g = p.createGraphics(W, H);
        g.pixelDensity(1);
        g.background(0);
        g.fill(255);
        g.noStroke();
        g.textFont('Georgia');
        g.textSize(52);
        g.textAlign(p.LEFT, p.TOP);

        var startY = 80;
        var lineH = 90;
        for (var li = 0; li < lines.length; li++) {
          g.text(lines[li], 50, startY + li * lineH);
        }

        g.loadPixels();
        layerA = [];
        layerB = [];
        var step = 3;
        for (var y = 0; y < H; y += step) {
          for (var x = 0; x < W; x += step) {
            var idx = (y * W + x) * 4;
            if (g.pixels[idx] > 128) {
              // Layer A: familiar
              layerA.push({
                hx: x, hy: y,
                x: x, y: y,
                n: Math.random() * 1000,
                size: 1.8,
              });
              // Layer B: strange — same home, will drift
              layerB.push({
                hx: x, hy: y,
                x: x, y: y,
                n: Math.random() * 1000 + 5000,
                size: 2.2,
                driftPhase: Math.random() * Math.PI * 2,
                driftAmp: 1 + Math.random() * 3,
              });
            }
          }
        }
        g.remove();
      }

      p.draw = function() {
        p.background(25, 24, 30);

        var t = p.frameCount * 0.003; // slow time
        var invasion = Math.min(t * 0.15, 1); // 0→1 over ~22 seconds

        // Layer A: familiar (fades as invasion grows)
        var alphaA = (1 - invasion * 0.7) * 200;
        for (var i = 0; i < layerA.length; i++) {
          var a = layerA[i];
          // Gentle breathing
          var nx = p.noise(a.n, p.frameCount * 0.005) * 2 - 1;
          var ny = p.noise(a.n + 300, p.frameCount * 0.005) * 2 - 1;
          a.x = a.hx + nx * 1.5;
          a.y = a.hy + ny * 1.5;

          // Warm off-white
          p.noStroke();
          p.fill(225, 218, 205, alphaA);
          p.ellipse(a.x, a.y, a.size, a.size);
        }

        // Layer B: strange (appears and drifts as invasion grows)
        var alphaB = invasion * 220;
        for (var j = 0; j < layerB.length; j++) {
          var b = layerB[j];

          // Drift increases with invasion
          var drift = invasion * b.driftAmp;
          var angle = p.noise(b.n, p.frameCount * 0.003) * Math.PI * 2;
          // Also add a slow rotation component
          var rotAngle = p.frameCount * 0.0008 + b.driftPhase;
          var rx = Math.cos(rotAngle) * drift * 2;
          var ry = Math.sin(rotAngle) * drift * 2;

          b.x = b.hx + Math.cos(angle) * drift + rx;
          b.y = b.hy + Math.sin(angle) * drift + ry;

          // Cool blue-grey
          var hueShift = p.noise(b.n + 800, p.frameCount * 0.002) * 30;
          p.noStroke();
          p.fill(110 + hueShift, 135 + hueShift * 0.5, 175, alphaB);
          p.ellipse(b.x, b.y, b.size, b.size);
        }

        // Time indicator
        p.fill(60);
        p.noStroke();
        p.textFont('monospace');
        p.textSize(11);
        p.textAlign(p.LEFT, p.TOP);
        var pct = Math.round(invasion * 100);
        p.text('invasion: ' + pct + '%', 10, 10);
      };

      // Click to reset
      p.mousePressed = function() {
        if (p.mouseX > 0 && p.mouseX < W && p.mouseY > 0 && p.mouseY < H) {
          p.frameCount = 0;
        }
      };
    });
  })();
  </script>
</Base>
