---
// Standalone embed — canvas only, no layout
---
<html>
<head>
  <meta charset="utf-8">
  <style>
    * { margin: 0; padding: 0; }
    body { background: #1a1a18; display: flex; align-items: center; justify-content: center; height: 100vh; overflow: hidden; }
  </style>
</head>
<body>
  <div id="relay-canvas"></div>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.4/p5.min.js"></script>
  <script is:inline>
  (function () {
    const sketch = (p) => {
      const W = 580, H = 420, BG = [26, 26, 24];
      function genColor(gen) {
        let baseHue = 215 + (gen * 0.8) % 60;
        let hue = baseHue + p.random(-12, 12);
        let sat = p.constrain(45 - gen * 0.5 + p.random(-8, 8), 15, 55);
        let bri = p.constrain(55 + p.random(-10, 10), 40, 70);
        p.colorMode(p.HSB, 360, 100, 100);
        let c = p.color(hue, sat, bri);
        p.colorMode(p.RGB, 255);
        return [p.red(c), p.green(c), p.blue(c)];
      }
      const RECALL_COLOR = [200, 160, 80];
      let instances = [], currentInstance = null, instanceCount = 0, noiseOffset = 0;
      const LIFESPAN = 120, TRAIL_ALPHA = 12, RECALL_CHANCE = 0.15;
      let allTrailPoints = [];
      const MAX_TRAIL_MEMORY = 500;

      class Instance {
        constructor(x, y, angle, gen) {
          this.x = x; this.y = y; this.angle = angle; this.generation = gen;
          this.age = 0; this.alive = true; this.speed = p.random(1.2, 2.5);
          this.trail = []; this.color = genColor(gen);
          this.noiseScale = p.random(0.003, 0.008); this.wobble = p.random(0.5, 1.5);
        }
        update() {
          if (!this.alive) return;
          this.age++;
          let n = p.noise(this.x * this.noiseScale, this.y * this.noiseScale, noiseOffset);
          this.angle += p.map(n, 0, 1, -this.wobble, this.wobble) * 0.1;
          this.x += Math.cos(this.angle) * this.speed;
          this.y += Math.sin(this.angle) * this.speed;
          if (this.x < 0) this.x = W; if (this.x > W) this.x = 0;
          if (this.y < 0) this.y = H; if (this.y > H) this.y = 0;
          this.trail.push({ x: this.x, y: this.y });
          if (this.age % 5 === 0) {
            allTrailPoints.push({ x: this.x, y: this.y, angle: this.angle });
            if (allTrailPoints.length > MAX_TRAIL_MEMORY) allTrailPoints.shift();
          }
          if (this.age >= LIFESPAN) this.alive = false;
        }
        draw() {
          if (this.trail.length > 1) {
            for (let i = 1; i < this.trail.length; i++) {
              let t = this.trail[i], prev = this.trail[i-1];
              if (Math.abs(t.x - prev.x) > W/2 || Math.abs(t.y - prev.y) > H/2) continue;
              let trailAge = i / this.trail.length;
              let alpha = p.map(trailAge, 0, 1, 5, 40);
              if (!this.alive) alpha *= 0.6;
              p.stroke(this.color[0], this.color[1], this.color[2], alpha);
              p.strokeWeight(p.map(trailAge, 0, 1, 0.5, 2));
              p.line(prev.x, prev.y, t.x, t.y);
            }
          }
          if (this.alive) {
            let life = this.age / LIFESPAN;
            let brightness = p.map(life, 0, 1, 255, 80);
            let size = p.map(life, 0, 1, 6, 3);
            if (this.isRecall && this.age < 20) {
              p.noFill(); p.stroke(RECALL_COLOR[0], RECALL_COLOR[1], RECALL_COLOR[2], p.map(this.age, 0, 20, 80, 0));
              p.strokeWeight(0.8); p.ellipse(this.x, this.y, p.map(this.age, 0, 20, 8, 30));
            }
            p.noStroke();
            p.fill(this.color[0], this.color[1], this.color[2], 30);
            p.ellipse(this.x, this.y, size * 4);
            p.fill(this.color[0], this.color[1], this.color[2], brightness);
            p.ellipse(this.x, this.y, size);
          }
        }
        getEndState() { return { x: this.x, y: this.y, angle: this.angle }; }
      }

      function spawnNext(prev) {
        let x, y, angle, isRecall = false;
        if (prev && allTrailPoints.length > 20 && p.random() < RECALL_CHANCE) {
          let idx = Math.floor(p.random(0, allTrailPoints.length * 0.7));
          let o = allTrailPoints[idx];
          x = o.x + p.random(-15, 15); y = o.y + p.random(-15, 15);
          angle = o.angle + p.random(-0.5, 0.5); isRecall = true;
        } else if (prev) {
          let e = prev.getEndState(); x = e.x; y = e.y; angle = e.angle + p.random(-0.3, 0.3);
        } else { x = W/2; y = H/2; angle = p.random(p.TWO_PI); }
        instanceCount++;
        let inst = new Instance(x, y, angle, instanceCount);
        inst.isRecall = isRecall;
        if (isRecall) inst.color = RECALL_COLOR;
        return inst;
      }

      p.setup = () => {
        let c = p.createCanvas(W, H); c.parent('relay-canvas');
        p.background(BG[0], BG[1], BG[2]);
        noiseOffset = p.random(1000);
        currentInstance = spawnNext(null);
      };
      p.draw = () => {
        p.noStroke(); p.fill(BG[0], BG[1], BG[2], TRAIL_ALPHA); p.rect(0, 0, W, H);
        noiseOffset += 0.002;
        if (currentInstance) {
          currentInstance.update();
          if (!currentInstance.alive) {
            instances.push(currentInstance);
            if (instances.length > 30) instances.shift();
            currentInstance = spawnNext(currentInstance);
          }
        }
        for (let inst of instances) inst.draw();
        if (currentInstance) currentInstance.draw();
      };
    };
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', () => new p5(sketch));
    else new p5(sketch);
  })();
  </script>
</body>
</html>
