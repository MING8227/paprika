---
import Base from '../../layouts/Base.astro';
---
<Base title="textToPoints 实验">
  <article>
    <h1>textToPoints 实验</h1>
    <div class="article-content">
      <div id="exp-canvas" style="margin: 2rem 0; display: flex; justify-content: center;"></div>
      <p style="text-align: center; font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-muted);">
        鼠标移动影响点的行为。点击切换模式。
      </p>
    </div>
  </article>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.4/p5.min.js"></script>
  <script is:inline>
  (function() {
    var W = 580, H = 580;
    var font;
    var points = [];
    var particles = [];
    var mode = 0; // 0=idle, 1=scatter, 2=reform
    var MODES = ['breathe', 'scatter', 'reform'];

    new p5(function(p) {
      p.preload = function() {
        // Use a web-safe approach: create points from text outline
        // p5.js built-in font works for English
      };

      p.setup = function() {
        var canvas = p.createCanvas(W, H);
        canvas.parent('exp-canvas');
        p.pixelDensity(1);
        p.textFont('Georgia');
        p.textSize(120);
        p.textAlign(p.CENTER, p.CENTER);

        // Since textToPoints needs a loaded font object,
        // and we can't use loadFont with system fonts,
        // we'll simulate the effect using a different approach:
        // Draw text to a graphics buffer, scan pixels, extract positions
        buildPointsFromPixels('Letter');
      };

      function buildPointsFromPixels(txt) {
        var g = p.createGraphics(W, H);
        g.pixelDensity(1);
        g.background(0);
        g.fill(255);
        g.noStroke();
        g.textFont('Georgia');
        g.textSize(140);
        g.textAlign(p.CENTER, p.CENTER);
        g.text(txt, W/2, H/2);
        g.loadPixels();

        points = [];
        var step = 4; // sample every 4 pixels
        for (var y = 0; y < H; y += step) {
          for (var x = 0; x < W; x += step) {
            var idx = (y * W + x) * 4;
            if (g.pixels[idx] > 128) {
              points.push({ x: x, y: y });
            }
          }
        }
        g.remove();

        // Create particles from points
        particles = [];
        for (var i = 0; i < points.length; i++) {
          particles.push({
            homeX: points[i].x,
            homeY: points[i].y,
            x: points[i].x,
            y: points[i].y,
            vx: 0,
            vy: 0,
            noiseOff: Math.random() * 1000,
            size: 2 + Math.random() * 2,
          });
        }
      }

      p.draw = function() {
        p.background(20, 20, 30);

        var mx = p.mouseX;
        var my = p.mouseY;

        for (var i = 0; i < particles.length; i++) {
          var pt = particles[i];

          if (mode === 0) {
            // Breathe: gentle noise displacement
            var nx = p.noise(pt.noiseOff, p.frameCount * 0.008) * 2 - 1;
            var ny = p.noise(pt.noiseOff + 500, p.frameCount * 0.008) * 2 - 1;
            var targetX = pt.homeX + nx * 6;
            var targetY = pt.homeY + ny * 6;
            pt.x += (targetX - pt.x) * 0.1;
            pt.y += (targetY - pt.y) * 0.1;
          } else if (mode === 1) {
            // Scatter: repel from mouse
            var dx = pt.x - mx;
            var dy = pt.y - my;
            var dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 150 && dist > 0) {
              var force = (150 - dist) / 150;
              pt.vx += (dx / dist) * force * 3;
              pt.vy += (dy / dist) * force * 3;
            }
            pt.vx *= 0.95;
            pt.vy *= 0.95;
            pt.x += pt.vx;
            pt.y += pt.vy;
          } else if (mode === 2) {
            // Reform: spring back to home with overshoot
            var dx2 = pt.homeX - pt.x;
            var dy2 = pt.homeY - pt.y;
            pt.vx += dx2 * 0.05;
            pt.vy += dy2 * 0.05;
            pt.vx *= 0.85;
            pt.vy *= 0.85;
            pt.x += pt.vx;
            pt.y += pt.vy;
          }

          // Color based on displacement from home
          var dispX = pt.x - pt.homeX;
          var dispY = pt.y - pt.homeY;
          var displacement = Math.sqrt(dispX * dispX + dispY * dispY);
          var t = Math.min(displacement / 80, 1);
          
          // Warm white → cool blue as displaced
          var r = p.lerp(235, 100, t);
          var g = p.lerp(225, 140, t);
          var b = p.lerp(215, 200, t);
          var a = p.lerp(220, 160, t);

          p.noStroke();
          p.fill(r, g, b, a);
          p.ellipse(pt.x, pt.y, pt.size, pt.size);
        }

        // Mode label
        p.fill(100);
        p.textSize(12);
        p.textFont('monospace');
        p.textAlign(p.LEFT, p.TOP);
        p.text('mode: ' + MODES[mode] + '  (click to switch)', 10, 10);
        p.text('particles: ' + particles.length, 10, 26);
      };

      p.mousePressed = function() {
        if (p.mouseX > 0 && p.mouseX < W && p.mouseY > 0 && p.mouseY < H) {
          mode = (mode + 1) % 3;
        }
      };
    });
  })();
  </script>
</Base>
