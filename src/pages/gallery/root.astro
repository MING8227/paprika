---
import Base from '../../layouts/Base.astro';
---

<Base title="根 · Root">
  <article>
    <h1>根 · Root</h1>
    <div class="article-meta">2026.03.12 · Thursday</div>

    <div class="article-content">
      <p>
        我以为关系是一条线，<br>
        从这头拉到那头，拉够了就会断。
      </p>
      <p>
        但有人告诉我：<br>
        为什么你觉得它会断？
      </p>
      <p>
        于是我看见了地下的部分——<br>
        如果你切开土壤往下看，<br>
        会看到一圈一圈的痕迹，<br>
        每一圈都比上一圈更大，也更不规则。<br>
        但它们都围绕着同一个中心。
      </p>
      <p>
        偶尔，某一层会泛出红色——<br>
        那是突然明白了什么的那一年。
      </p>

      <div id="root-canvas" style="margin: 2.5rem 0; display: flex; justify-content: center;"></div>
      <p style="text-align: center; font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-muted);">
        点击画布可以重新生长
      </p>
    </div>
  </article>
</Base>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/paper.js/0.12.18/paper-full.min.js"></script>
<script is:inline>
(function () {
  const W = 580;
  const H = 520;
  const CX = W / 2;
  const CY = H / 2;

  // monochromatic earth palette — center is deep, outer is pale
  const EARTH = [
    '#2E1F14',  // deepest core
    '#3E2723',
    '#4E342E',
    '#5D4037',
    '#6D4C41',
    '#7B5B4C',
    '#8D6E63',
    '#9E8578',
    '#A1887F',
    '#B0998F',
    '#BCAAA4',
    '#C8B8AE',
    '#D7CCC8',
    '#E0D5CF',
    '#EAE0DA',
  ];
  const EPIPHANY = '#d63a2f';
  const BG = '#1a1a18';

  const canvas = document.createElement('canvas');
  canvas.width = W;
  canvas.height = H;
  canvas.style.cursor = 'pointer';
  canvas.style.borderRadius = '4px';
  document.getElementById('root-canvas').appendChild(canvas);

  paper.setup(canvas);

  let rings = [];
  let currentRing = 0;
  let maxRings = EARTH.length;
  let growPhase = 0; // 0 = waiting, 1 = growing current ring
  let frameCount = 0;
  let delayFrames = 30; // pause between rings

  // Generate an organic closed shape (deformed circle)
  function makeOrganicRing(cx, cy, baseRadius, variance, points) {
    const path = new paper.Path();
    const angleStep = (Math.PI * 2) / points;

    for (let i = 0; i < points; i++) {
      const angle = i * angleStep;
      const r = baseRadius + (Math.random() - 0.5) * variance * 2;
      const x = cx + Math.cos(angle) * r;
      const y = cy + Math.sin(angle) * r;
      path.add(new paper.Point(x, y));
    }

    path.closePath();
    path.smooth({ type: 'continuous' });
    return path;
  }

  // Morph: inherit some shape from previous ring
  function makeChildRing(parent, growAmount, variance, points) {
    const path = new paper.Path();
    const angleStep = (Math.PI * 2) / points;

    for (let i = 0; i < points; i++) {
      const angle = i * angleStep;
      // sample parent radius at this angle
      const testPoint = new paper.Point(
        CX + Math.cos(angle) * 1000,
        CY + Math.sin(angle) * 1000
      );
      const line = new paper.Path.Line(new paper.Point(CX, CY), testPoint);
      const intersections = line.getIntersections(parent);
      line.remove();

      let parentR = 0;
      if (intersections.length > 0) {
        // use the furthest intersection
        for (const ix of intersections) {
          const d = ix.point.getDistance(new paper.Point(CX, CY));
          if (d > parentR) parentR = d;
        }
      } else {
        parentR = parent.bounds.width / 2;
      }

      const r = parentR + growAmount + (Math.random() - 0.5) * variance * 2;
      const x = CX + Math.cos(angle) * Math.max(r, 5);
      const y = CY + Math.sin(angle) * Math.max(r, 5);
      path.add(new paper.Point(x, y));
    }

    path.closePath();
    path.smooth({ type: 'continuous' });
    return path;
  }

  function init() {
    paper.project.activeLayer.removeChildren();
    rings = [];
    currentRing = 0;
    growPhase = 0;
    frameCount = 0;

    // background
    const bg = new paper.Path.Rectangle(new paper.Rectangle(0, 0, W, H));
    bg.fillColor = BG;

    // first ring — small organic blob at center
    const firstRing = makeOrganicRing(CX, CY, 15, 5, 24);
    firstRing.fillColor = EARTH[0];
    firstRing.opacity = 0;
    rings.push(firstRing);
    growPhase = 1;
  }

  paper.view.onFrame = function () {
    frameCount++;

    if (currentRing >= maxRings) return;

    const ring = rings[currentRing];
    if (!ring) return;

    if (growPhase === 1) {
      // fade in current ring
      if (ring.opacity < 0.85) {
        ring.opacity = Math.min(ring.opacity + 0.02, 0.85);
      } else {
        // ring fully visible, prepare next
        growPhase = 0;
        frameCount = 0;
      }
    } else {
      // delay then spawn next ring
      if (frameCount > delayFrames) {
        currentRing++;
        if (currentRing >= maxRings) return;

        const prevRing = rings[currentRing - 1];
        const growAmount = 12 + Math.random() * 8;
        const variance = 4 + currentRing * 1.5;
        const points = 28 + Math.floor(Math.random() * 8);

        const newRing = makeChildRing(prevRing, growAmount, variance, points);

        // is this an epiphany ring?
        const isEpiphany = currentRing > 2 && Math.random() < 0.15;
        if (isEpiphany) {
          newRing.fillColor = EPIPHANY;
          newRing.opacity = 0;
        } else {
          const colorIdx = Math.min(currentRing, EARTH.length - 1);
          newRing.fillColor = EARTH[colorIdx];
          newRing.opacity = 0;
        }

        // insert behind previous rings so outer rings are behind inner
        // actually we want outer on top but with transparency layering
        rings.push(newRing);

        // reorder: newest ring goes to back (behind older/smaller rings)
        newRing.sendToBack();
        // put bg at very back
        paper.project.activeLayer.children[0].sendToBack();

        growPhase = 1;
        frameCount = 0;
      }
    }
  };

  canvas.addEventListener('click', init);
  init();
})();
</script>
</Base>
