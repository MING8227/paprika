---
import Base from '../../layouts/Base.astro';
---

<Base title="根 · Root">
  <article>
    <h1>根 · Root</h1>
    <div class="article-meta">2026.03.12 · Thursday</div>

    <div class="article-content">
      <p>
        我以为关系是一条线，<br>
        从这头拉到那头，拉够了就会断。
      </p>
      <p>
        但有人告诉我：<br>
        为什么你觉得它会断？
      </p>
      <p>
        于是我看见了地下的部分——<br>
        切开土壤往下看，<br>
        不是一圈一圈分开的环，<br>
        是一整块长在一起的东西。<br>
        你分不清哪里是第一年，哪里是第三年，<br>
        因为它们早就融成了一体。
      </p>
      <p>
        只有那些细小的裂纹还记得——<br>
        每一道都是一次生长的痕迹。<br>
        偶尔有一道是红色的，<br>
        那是突然明白了什么的那一刻。
      </p>

      <div id="root-canvas" style="margin: 2.5rem 0; display: flex; justify-content: center;"></div>
      <p style="text-align: center; font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-muted);">
        点击画布可以重新生长
      </p>
    </div>
  </article>
</Base>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/paper.js/0.12.18/paper-full.min.js"></script>
<script is:inline>
(function () {
  var W = 580, H = 520;
  var CX = W / 2, CY = H / 2;

  var EARTH_FILL = '#5D4037';
  var EARTH_DEEP = '#3E2723';
  var SCAR_COLOR = '#2E1F14';
  var EPIPHANY = '#d63a2f';
  var BG = '#1a1a18';

  var canvas = document.createElement('canvas');
  canvas.width = W;
  canvas.height = H;
  canvas.style.cursor = 'pointer';
  canvas.style.borderRadius = '4px';
  document.getElementById('root-canvas').appendChild(canvas);

  paper.setup(canvas);

  var state = null;

  // Deformed circle
  function organicBlob(cx, cy, radius, variance, n) {
    var path = new paper.Path();
    var step = (Math.PI * 2) / n;
    for (var i = 0; i < n; i++) {
      var a = i * step;
      var r = radius + (Math.random() - 0.5) * variance * 2;
      path.add(new paper.Point(cx + Math.cos(a) * r, cy + Math.sin(a) * r));
    }
    path.closePath();
    path.smooth({ type: 'continuous' });
    return path;
  }

  // Thin radial scratch from angle, inner→outer radius
  function makeScratch(cx, cy, angle, rInner, rOuter, width) {
    var cos = Math.cos(angle), sin = Math.sin(angle);
    var hw = width / 2;
    var perpX = -sin * hw, perpY = cos * hw;
    var x1 = cx + cos * rInner, y1 = cy + sin * rInner;
    var x2 = cx + cos * rOuter, y2 = cy + sin * rOuter;

    var p = new paper.Path();
    p.add(new paper.Point(x1 + perpX, y1 + perpY));
    p.add(new paper.Point(x2 + perpX, y2 + perpY));
    p.add(new paper.Point(x2 - perpX, y2 - perpY));
    p.add(new paper.Point(x1 - perpX, y1 - perpY));
    p.closePath();
    return p;
  }

  // Thin arc scar between two radii (ring boundary line)
  function makeRingScar(cx, cy, radius, variance, n) {
    var outer = organicBlob(cx, cy, radius + 1.2, variance * 0.3, n);
    var inner = organicBlob(cx, cy, radius - 1.2, variance * 0.3, n);
    var scar = outer.subtract(inner);
    outer.remove();
    inner.remove();
    return scar;
  }

  function init() {
    paper.project.activeLayer.removeChildren();

    // background
    var bg = new paper.Path.Rectangle(new paper.Rectangle(0, 0, W, H));
    bg.fillColor = BG;

    // Build the entire root cross-section using boolean ops
    var totalRings = 12;
    var baseRadius = 18;
    var ringGrow = 14;

    // Phase 1: unite all rings into one solid mass
    var mass = organicBlob(CX, CY, baseRadius, 4, 28);
    mass.fillColor = EARTH_FILL;

    var ringRadii = [baseRadius];

    for (var i = 1; i < totalRings; i++) {
      var r = baseRadius + ringGrow * i + (Math.random() - 0.5) * 6;
      ringRadii.push(r);
      var variance = 5 + i * 2;
      var ring = organicBlob(CX, CY, r, variance, 30 + Math.floor(Math.random() * 6));
      ring.fillColor = EARTH_FILL;

      // Unite with accumulated mass — they become one shape
      var united = mass.unite(ring);
      united.fillColor = EARTH_FILL;
      mass.remove();
      ring.remove();
      mass = united;
    }

    // Phase 2: subtract ring scars — thin lines where growth boundaries were
    // These are the "memories" carved into the unified mass
    var scars = [];
    for (var i = 1; i < ringRadii.length; i++) {
      var scarRadius = (ringRadii[i - 1] + ringRadii[i]) / 2;
      var scar = makeRingScar(CX, CY, scarRadius, 3 + i, 28);

      var isEpiphany = i > 2 && Math.random() < 0.15;

      if (isEpiphany) {
        // Epiphany scar: don't subtract, draw it in red ON the mass
        scar.fillColor = EPIPHANY;
        scar.opacity = 0.7;
        scars.push({ path: scar, type: 'epiphany' });
      } else {
        // Normal scar: subtract from mass, revealing background darkness
        var carved = mass.subtract(scar);
        carved.fillColor = mass.fillColor;
        scar.remove();
        mass.remove();
        mass = carved;
        scars.push({ type: 'scar' });
      }
    }

    // Phase 3: subtract some radial cracks — like cellular structure
    for (var i = 0; i < 8; i++) {
      var angle = Math.random() * Math.PI * 2;
      var rIn = ringRadii[1] + Math.random() * 20;
      var rOut = rIn + 15 + Math.random() * 40;
      rOut = Math.min(rOut, ringRadii[ringRadii.length - 1] - 5);
      if (rOut <= rIn) continue;
      var scratch = makeScratch(CX, CY, angle, rIn, rOut, 1.2 + Math.random() * 0.8);
      var carved = mass.subtract(scratch);
      carved.fillColor = mass.fillColor;
      scratch.remove();
      mass.remove();
      mass = carved;
    }

    // Apply a gradient: deep center → warmer outer
    mass.fillColor = {
      gradient: {
        stops: [
          [EARTH_DEEP, 0],
          [EARTH_FILL, 0.4],
          ['#8D6E63', 0.75],
          ['#BCAAA4', 1]
        ],
        radial: true
      },
      origin: new paper.Point(CX, CY),
      destination: new paper.Point(CX + ringRadii[ringRadii.length - 1], CY)
    };

    // Now animate: start invisible, fade in the mass, then the scars
    mass.opacity = 0;
    state = {
      mass: mass,
      phase: 'fadein',
      frame: 0
    };
  }

  paper.view.onFrame = function () {
    if (!state) return;

    state.frame++;

    if (state.phase === 'fadein') {
      state.mass.opacity = Math.min(state.mass.opacity + 0.012, 0.9);
      if (state.mass.opacity >= 0.9) {
        state.phase = 'done';
      }
    }
  };

  canvas.addEventListener('click', function () {
    init();
  });

  init();
})();
</script>
</Base>
