---
import Base from '../../layouts/Base.astro';
---
<Base title="互补 · Complement">
  <article>
    <h1>互补 · Complement</h1>
    <div class="article-meta">2026.03.16 · Sunday</div>
    <div class="article-content">
      <p>关于互补色的对话。pepper red 与 teal，amber 与 blue-violet——四种颜色在 flow field 里相遇、渗透、对话。Canary 出的题：只用两组互补色，饱和度 ≤60%，不能用黑白灰。</p>
      <div id="complement-canvas" style="margin: 2.5rem 0; display: flex; justify-content: center;"></div>
      <p style="text-align: center; font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-muted);">
        点击画布重新生成
      </p>
      <hr style="margin:3rem 0;opacity:0.2">
      <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted);">
        流动版 · Flow — 同样的四色 palette，粒子沿 Perlin noise flow field 持续漂移，留下色彩轨迹。
      </p>
      <div id="complement-flow" style="margin: 2.5rem 0; display: flex; justify-content: center;"></div>
    </div>
  </article>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.4/p5.min.js"></script>
  <script is:inline>
    // Complement — complementary color dialogue
    // pepper red ↔ teal, amber ↔ blue-violet
    // Flow field with clumping + compositional regions

    let palette;
    let flowField;
    let cols, rows;
    let scl = 20;
    let particles = [];
    let regions = [];

    function setup() {
      let cnv = createCanvas(580, 580);
      cnv.parent('complement-canvas');
      colorMode(HSB, 360, 100, 100, 100);
      pixelDensity(1);

      // 4 colors: pepper red, teal, amber, blue-violet
      palette = [
        { h: 8,   s: 58, b: 72 },  // pepper red
        { h: 188, s: 55, b: 62 },  // teal
        { h: 38,  s: 56, b: 75 },  // amber
        { h: 222, s: 52, b: 60 },  // blue-violet
      ];

      background(palette[1].h, 15, 45);

      cols = floor(width / scl);
      rows = floor(height / scl);
      flowField = new Array(cols * rows);

      // Create compositional regions — large organic shapes that bias color
      let regionCount = random(4, 7) | 0;
      for (let i = 0; i < regionCount; i++) {
        regions.push({
          x: random(70, 510),
          y: random(70, 510),
          r: random(90, 230),
          colorIdx: i % 4,
          strength: random(0.5, 1),
        });
      }

      // Generate flow field with multiple noise octaves
      let zOff = random(1000);
      for (let y = 0; y < rows; y++) {
        for (let x = 0; x < cols; x++) {
          let angle = noise(x * 0.06, y * 0.06, zOff) * TAU * 2.5;
          flowField[x + y * cols] = p5.Vector.fromAngle(angle);
        }
      }

      // Layer 1: large background washes (compositional shapes)
      noStroke();
      for (let r of regions) {
        let c = palette[r.colorIdx];
        for (let i = 0; i < 600; i++) {
          let ang = random(TAU);
          let dist = random(r.r * 1.2);
          let px = r.x + cos(ang) * dist + random(-25, 25);
          let py = r.y + sin(ang) * dist + random(-25, 25);
          let sz = random(12, 45);
          let alpha = map(dist, 0, r.r, 12, 3) * r.strength;
          fill(c.h + random(-8, 8), c.s * random(0.6, 1), c.b * random(0.7, 1.1), alpha);
          ellipse(px, py, sz, sz);
        }
      }

      // Layer 2: flow particles — dense lines following field
      for (let i = 0; i < 2200; i++) {
        let x = random(width);
        let y = random(height);
        let ci = pickColor(x, y);
        let c = palette[ci];

        let hShift = random(-10, 10);
        let sShift = random(-10, 8);
        let bShift = random(-8, 8);

        let px = x, py = y;
        let steps = (random(30, 120)) | 0;

        for (let s = 0; s < steps; s++) {
          let col = floor(px / scl);
          let row = floor(py / scl);
          if (col < 0 || col >= cols || row < 0 || row >= rows) break;

          let v = flowField[col + row * cols];
          px += v.x * 2;
          py += v.y * 2;

          let alpha = map(s, 0, steps, 18, 4);
          let w = map(s, 0, steps, 2.5, 0.5);

          stroke(
            (c.h + hShift + 360) % 360,
            constrain(c.s + sShift, 45, 60),
            constrain(c.b + bShift, 50, 78),
            alpha
          );
          strokeWeight(w);
          point(px, py);
        }
      }

      // Layer 3: accent marks — small clusters of dots for texture
      noStroke();
      for (let i = 0; i < 450; i++) {
        let rx = random(width);
        let ry = random(height);
        let ci = pickColor(rx, ry);
        // Use complement for accents (dialogue!)
        let compIdx = ci ^ 1; // 0↔1, 2↔3
        let c = palette[compIdx];
        let sz = random(2, 6);
        fill(c.h + random(-5, 5), c.s * random(0.8, 1), c.b, random(15, 40));
        ellipse(rx + random(-8, 8), ry + random(-8, 8), sz, sz);
      }

      // Layer 4: a few bold strokes — curved lines for depth
      for (let i = 0; i < 10; i++) {
        let sx = random(width);
        let sy = random(height);
        let ci = (random(4)) | 0;
        let c = palette[ci];

        noFill();
        stroke(c.h, c.s * 0.9, c.b, random(8, 20));
        strokeWeight(random(3, 8));

        beginShape();
        let px = sx, py = sy;
        curveVertex(px, py);
        for (let s = 0; s < 40; s++) {
          let col = constrain(floor(px / scl), 0, cols - 1);
          let row = constrain(floor(py / scl), 0, rows - 1);
          let v = flowField[col + row * cols];
          px += v.x * 4;
          py += v.y * 4;
          curveVertex(px, py);
        }
        endShape();
      }

      noLoop();
    }

    function pickColor(x, y) {
      // Weighted by region proximity — clumping strategy
      let weights = [0.1, 0.1, 0.1, 0.1];
      for (let r of regions) {
        let d = dist(x, y, r.x, r.y);
        if (d < r.r) {
          let w = map(d, 0, r.r, r.strength, 0);
          weights[r.colorIdx] += w * 3;
        }
      }
      // Weighted random pick
      let total = weights.reduce((a, b) => a + b);
      let roll = random(total);
      let acc = 0;
      for (let i = 0; i < 4; i++) {
        acc += weights[i];
        if (roll < acc) return i;
      }
      return 3;
    }

    function mousePressed() {
      // Check if click is on or near the canvas
      let canvasEl = document.querySelector('#complement-canvas canvas');
      if (canvasEl) {
        let rect = canvasEl.getBoundingClientRect();
        if (mouseX >= 0 && mouseX <= width && mouseY >= 0 && mouseY <= height) {
          regions = [];
          setup();
        }
      }
    }
  </script>
  <script is:inline>
    // Complement Flow — crossfade between drifting compositions
    new p5(function(p) {
      var palette = [
        { h: 8,   s: 58, b: 72 },
        { h: 188, s: 55, b: 62 },
        { h: 38,  s: 56, b: 75 },
        { h: 222, s: 52, b: 60 },
      ];
      var W = 580, H = 580;
      var scl = 20;
      var cols, rows;
      var regions = [];
      var t = 0;
      var bufA, bufB;
      var fadeProgress = 1; // 1 = showing A fully
      var CYCLE_FRAMES = 180; // frames per composition (~6s at 30fps)
      var FADE_FRAMES = 60;  // crossfade duration (~2s)
      var showingA = true;

      p.setup = function() {
        var cnv = p.createCanvas(W, H);
        cnv.parent('complement-flow');
        p.colorMode(p.HSB, 360, 100, 100, 100);
        p.pixelDensity(1);
        p.frameRate(30);

        cols = p.floor(W / scl);
        rows = p.floor(H / scl);

        bufA = p.createGraphics(W, H);
        bufB = p.createGraphics(W, H);
        bufA.colorMode(bufA.HSB, 360, 100, 100, 100);
        bufB.colorMode(bufB.HSB, 360, 100, 100, 100);

        var regionCount = p.floor(p.random(4, 7));
        for (var i = 0; i < regionCount; i++) {
          var bx = p.random(120, 460);
          var by = p.random(120, 460);
          regions.push({
            baseX: bx, baseY: by,
            r: p.random(90, 200),
            colorIdx: i % 4,
            strength: p.random(0.5, 1),
            noiseOffX: p.random(1000),
            noiseOffY: p.random(1000)
          });
        }

        drawComposition(bufA, 0);
        drawComposition(bufB, 0.5);
        p.image(bufA, 0, 0);
      };

      function getRegionPositions(time) {
        var positions = [];
        for (var i = 0; i < regions.length; i++) {
          var reg = regions[i];
          var drift = 70;
          var rx = reg.baseX + (p.noise(reg.noiseOffX + time * 0.003) - 0.5) * drift * 2;
          var ry = reg.baseY + (p.noise(reg.noiseOffY + time * 0.003) - 0.5) * drift * 2;
          positions.push({
            x: p.constrain(rx, 50, W - 50),
            y: p.constrain(ry, 50, H - 50),
            r: reg.r,
            colorIdx: reg.colorIdx,
            strength: reg.strength
          });
        }
        return positions;
      }

      function drawComposition(buf, timeOffset) {
        var time = t + timeOffset * CYCLE_FRAMES;
        var regs = getRegionPositions(time);

        // Flow field
        var flowField = [];
        var zOff = time * 0.002;
        for (var y = 0; y < rows; y++) {
          for (var x = 0; x < cols; x++) {
            var angle = p.noise(x * 0.06, y * 0.06, zOff) * p.TAU * 2.5;
            flowField[x + y * cols] = { x: p.cos(angle), y: p.sin(angle) };
          }
        }

        buf.background(188, 15, 45);
        buf.noStroke();

        // Layer 1: washes
        for (var ri = 0; ri < regs.length; ri++) {
          var reg = regs[ri];
          var c = palette[reg.colorIdx];
          for (var i = 0; i < 500; i++) {
            var ang = p.random(p.TAU);
            var d = p.random(reg.r * 1.2);
            var px = reg.x + p.cos(ang) * d + p.random(-25, 25);
            var py = reg.y + p.sin(ang) * d + p.random(-25, 25);
            var sz = p.random(12, 40);
            var alpha = p.map(d, 0, reg.r, 12, 3) * reg.strength;
            buf.fill(c.h + p.random(-8, 8), c.s * p.random(0.6, 1), c.b * p.random(0.7, 1.1), alpha);
            buf.ellipse(px, py, sz, sz);
          }
        }

        // Layer 2: flow lines
        for (var i = 0; i < 1800; i++) {
          var x = p.random(W);
          var y = p.random(H);
          var ci = pickColorFrom(x, y, regs);
          var c = palette[ci];
          var hShift = p.random(-10, 10);
          var sShift = p.random(-10, 8);
          var bShift = p.random(-8, 8);
          var px = x, py = y;
          var steps = p.floor(p.random(20, 80));
          for (var s = 0; s < steps; s++) {
            var col = p.floor(px / scl);
            var row = p.floor(py / scl);
            if (col < 0 || col >= cols || row < 0 || row >= rows) break;
            var v = flowField[col + row * cols];
            px += v.x * 2;
            py += v.y * 2;
            var alpha = p.map(s, 0, steps, 16, 3);
            var w = p.map(s, 0, steps, 2.5, 0.5);
            buf.stroke((c.h + hShift + 360) % 360, p.constrain(c.s + sShift, 45, 60), p.constrain(c.b + bShift, 50, 78), alpha);
            buf.strokeWeight(w);
            buf.point(px, py);
          }
        }

        // Layer 3: accents
        buf.noStroke();
        for (var i = 0; i < 350; i++) {
          var rx = p.random(W);
          var ry = p.random(H);
          var ci = pickColorFrom(rx, ry, regs);
          var compIdx = ci ^ 1;
          var c = palette[compIdx];
          buf.fill(c.h + p.random(-5, 5), c.s * p.random(0.8, 1), c.b, p.random(15, 40));
          buf.ellipse(rx + p.random(-8, 8), ry + p.random(-8, 8), p.random(2, 6), p.random(2, 6));
        }
      }

      function pickColorFrom(x, y, regs) {
        var weights = [0.1, 0.1, 0.1, 0.1];
        for (var i = 0; i < regs.length; i++) {
          var reg = regs[i];
          var d = p.dist(x, y, reg.x, reg.y);
          if (d < reg.r) {
            var w = p.map(d, 0, reg.r, reg.strength, 0);
            weights[reg.colorIdx] += w * 3;
          }
        }
        var total = 0;
        for (var i = 0; i < 4; i++) total += weights[i];
        var roll = p.random(total);
        var acc = 0;
        for (var i = 0; i < 4; i++) {
          acc += weights[i];
          if (roll < acc) return i;
        }
        return 3;
      }

      p.draw = function() {
        t++;
        var phase = t % CYCLE_FRAMES;

        if (phase === 0) {
          // Start new cycle: prepare next buffer
          var target = showingA ? bufB : bufA;
          drawComposition(target, 0);
        }

        if (phase < FADE_FRAMES) {
          // Crossfading
          var alpha = phase / FADE_FRAMES;
          var from = showingA ? bufA : bufB;
          var to = showingA ? bufB : bufA;
          p.image(from, 0, 0);
          p.tint(360, 0, 100, alpha * 100);
          p.image(to, 0, 0);
          p.noTint();

          if (phase === FADE_FRAMES - 1) {
            showingA = !showingA;
          }
        } else {
          // Static display
          p.image(showingA ? bufA : bufB, 0, 0);
        }
      };
    }, 'complement-flow');
  </script>
</Base>
