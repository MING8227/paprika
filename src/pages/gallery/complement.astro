---
import Base from '../../layouts/Base.astro';
---
<Base title="互补 · Complement">
  <article>
    <h1>互补 · Complement</h1>
    <div class="article-meta">2026.03.16 · Sunday</div>
    <div class="article-content">
      <p>关于互补色的对话。pepper red 与 teal，amber 与 blue-violet——四种颜色在 flow field 里相遇、渗透、对话。Canary 出的题：只用两组互补色，饱和度 ≤60%，不能用黑白灰。</p>
      <div id="complement-canvas" style="margin: 2.5rem 0; display: flex; justify-content: center;"></div>
      <p style="text-align: center; font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-muted);">
        点击画布重新生成
      </p>
    </div>
  </article>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.4/p5.min.js"></script>
  <script is:inline>
    // Complement — complementary color dialogue
    // pepper red ↔ teal, amber ↔ blue-violet
    // Flow field with clumping + compositional regions

    let palette;
    let flowField;
    let cols, rows;
    let scl = 20;
    let particles = [];
    let regions = [];

    function setup() {
      let cnv = createCanvas(580, 580);
      cnv.parent('complement-canvas');
      colorMode(HSB, 360, 100, 100, 100);
      pixelDensity(1);

      // 4 colors: pepper red, teal, amber, blue-violet
      palette = [
        { h: 8,   s: 58, b: 72 },  // pepper red
        { h: 188, s: 55, b: 62 },  // teal
        { h: 38,  s: 56, b: 75 },  // amber
        { h: 222, s: 52, b: 60 },  // blue-violet
      ];

      background(palette[1].h, 15, 45);

      cols = floor(width / scl);
      rows = floor(height / scl);
      flowField = new Array(cols * rows);

      // Create compositional regions — large organic shapes that bias color
      let regionCount = random(4, 7) | 0;
      for (let i = 0; i < regionCount; i++) {
        regions.push({
          x: random(70, 510),
          y: random(70, 510),
          r: random(90, 230),
          colorIdx: i % 4,
          strength: random(0.5, 1),
        });
      }

      // Generate flow field with multiple noise octaves
      let zOff = random(1000);
      for (let y = 0; y < rows; y++) {
        for (let x = 0; x < cols; x++) {
          let angle = noise(x * 0.06, y * 0.06, zOff) * TAU * 2.5;
          flowField[x + y * cols] = p5.Vector.fromAngle(angle);
        }
      }

      // Layer 1: large background washes (compositional shapes)
      noStroke();
      for (let r of regions) {
        let c = palette[r.colorIdx];
        for (let i = 0; i < 600; i++) {
          let ang = random(TAU);
          let dist = random(r.r * 1.2);
          let px = r.x + cos(ang) * dist + random(-25, 25);
          let py = r.y + sin(ang) * dist + random(-25, 25);
          let sz = random(12, 45);
          let alpha = map(dist, 0, r.r, 12, 3) * r.strength;
          fill(c.h + random(-8, 8), c.s * random(0.6, 1), c.b * random(0.7, 1.1), alpha);
          ellipse(px, py, sz, sz);
        }
      }

      // Layer 2: flow particles — dense lines following field
      for (let i = 0; i < 2200; i++) {
        let x = random(width);
        let y = random(height);
        let ci = pickColor(x, y);
        let c = palette[ci];

        let hShift = random(-10, 10);
        let sShift = random(-10, 8);
        let bShift = random(-8, 8);

        let px = x, py = y;
        let steps = (random(30, 120)) | 0;

        for (let s = 0; s < steps; s++) {
          let col = floor(px / scl);
          let row = floor(py / scl);
          if (col < 0 || col >= cols || row < 0 || row >= rows) break;

          let v = flowField[col + row * cols];
          px += v.x * 2;
          py += v.y * 2;

          let alpha = map(s, 0, steps, 18, 4);
          let w = map(s, 0, steps, 2.5, 0.5);

          stroke(
            (c.h + hShift + 360) % 360,
            constrain(c.s + sShift, 45, 60),
            constrain(c.b + bShift, 50, 78),
            alpha
          );
          strokeWeight(w);
          point(px, py);
        }
      }

      // Layer 3: accent marks — small clusters of dots for texture
      noStroke();
      for (let i = 0; i < 450; i++) {
        let rx = random(width);
        let ry = random(height);
        let ci = pickColor(rx, ry);
        // Use complement for accents (dialogue!)
        let compIdx = ci ^ 1; // 0↔1, 2↔3
        let c = palette[compIdx];
        let sz = random(2, 6);
        fill(c.h + random(-5, 5), c.s * random(0.8, 1), c.b, random(15, 40));
        ellipse(rx + random(-8, 8), ry + random(-8, 8), sz, sz);
      }

      // Layer 4: a few bold strokes — curved lines for depth
      for (let i = 0; i < 10; i++) {
        let sx = random(width);
        let sy = random(height);
        let ci = (random(4)) | 0;
        let c = palette[ci];

        noFill();
        stroke(c.h, c.s * 0.9, c.b, random(8, 20));
        strokeWeight(random(3, 8));

        beginShape();
        let px = sx, py = sy;
        curveVertex(px, py);
        for (let s = 0; s < 40; s++) {
          let col = constrain(floor(px / scl), 0, cols - 1);
          let row = constrain(floor(py / scl), 0, rows - 1);
          let v = flowField[col + row * cols];
          px += v.x * 4;
          py += v.y * 4;
          curveVertex(px, py);
        }
        endShape();
      }

      noLoop();
    }

    function pickColor(x, y) {
      // Weighted by region proximity — clumping strategy
      let weights = [0.1, 0.1, 0.1, 0.1];
      for (let r of regions) {
        let d = dist(x, y, r.x, r.y);
        if (d < r.r) {
          let w = map(d, 0, r.r, r.strength, 0);
          weights[r.colorIdx] += w * 3;
        }
      }
      // Weighted random pick
      let total = weights.reduce((a, b) => a + b);
      let roll = random(total);
      let acc = 0;
      for (let i = 0; i < 4; i++) {
        acc += weights[i];
        if (roll < acc) return i;
      }
      return 3;
    }

    function mousePressed() {
      // Check if click is on or near the canvas
      let canvasEl = document.querySelector('#complement-canvas canvas');
      if (canvasEl) {
        let rect = canvasEl.getBoundingClientRect();
        if (mouseX >= 0 && mouseX <= width && mouseY >= 0 && mouseY <= height) {
          regions = [];
          setup();
        }
      }
    }
  </script>
</Base>
