<html><head><meta charset="utf-8"><style>*{margin:0;padding:0}body{overflow:hidden;background:#f2ede5}</style></head><body>
<div id="letter-canvas"></div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.4/p5.min.js"></script>
<script>
new p5(function(p){var W=400,H=400,LINES=10;p.setup=function(){p.createCanvas(W,H);p.colorMode(p.HSB,360,100,100,100);p.pixelDensity(1);p.noLoop();gen()};function gen(){p.background(40,8,95);p.noStroke();for(var i=0;i<2000;i++){p.fill(35,p.random(3,12),p.random(88,96),p.random(5,15));p.ellipse(p.random(W),p.random(H),p.random(2,6))}var mL=50,mR=W-40,sp=30,sY=45;for(var r=0;r<LINES;r++){var pr=r/(LINES-1),y=sY+r*sp;var h=p.lerp(30,215,pr*pr),s=p.lerp(45,20,pr),b=p.lerp(35,55,pr),w=p.lerp(1.8,0.8,pr),c=1-pr;drawLine(mL,y,mR,h,s,b,w,c,r)}}function drawLine(x1,y,x2,hue,sat,bri,wt,coh,row){var end=x1+(x2-x1)*p.random(0.7,1);if(row===LINES-1)end=x1+(x2-x1)*p.random(0.2,0.4);var segs=p.floor(p.random(10,18)),sw=(end-x1)/segs;for(var s=0;s<segs;s++){var sx=x1+s*sw,ex=sx+sw*p.random(0.5,0.95);if(p.random()>coh*0.7+0.3)continue;p.noFill();p.stroke((hue+p.random(-8,8)+360)%360,p.constrain(sat+p.random(-10,10),10,60),p.constrain(bri+p.random(-8,8),20,65),p.lerp(70,25,(1-coh)*(1-coh)));p.strokeWeight(wt*p.random(0.7,1.3));var wb=p.lerp(3,12,1-coh),j=(1-coh)*p.random(-5,5);p.beginShape();p.vertex(sx+j,y+p.random(-1,1)*(1-coh)*3);p.bezierVertex(sx+sw*0.33+j,y+p.random(-wb,wb),sx+sw*0.66+j,y+p.random(-wb,wb),ex+j,y+p.random(-1,1)*(1-coh)*5);p.endShape()}}}, 'letter-canvas');
</script></body></html>
