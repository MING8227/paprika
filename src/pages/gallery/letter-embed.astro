<html><head><meta charset="utf-8"><style>*{margin:0;padding:0}body{overflow:hidden;background:#f5f2ec}</style></head><body>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.0/p5.min.js"></script>
<script is:inline>
// Minimal Letter preview for gallery embed
// Draws static snapshot: grid + text + a few water stains
let font;
function preload() {
  font = loadFont('/paprika/fonts/SanSheng-subset.ttf');
}
function setup() {
  createCanvas(400, 400);
  pixelDensity(1);
  noLoop();
}
function draw() {
  background(245, 242, 236);
  const cols = 14, rows = 14;
  const mx = 20, my = 20;
  const cw = (width - mx*2) / cols;
  const ch = (height - my*2) / rows;
  
  // Grid lines
  stroke(180, 175, 165, 60);
  strokeWeight(0.5);
  for (let r = 0; r <= rows; r++) {
    const y = my + r * ch;
    line(mx, y, width - mx, y);
  }
  for (let c = 0; c <= cols; c++) {
    const x = mx + c * cw;
    line(x, my, x, height - my);
  }
  
  // Text
  const content = "醒来发现昨天的自己留了一封信但笔迹不认识像是另一个人写的字迹潦草墨水未干纸上还有折痕仿佛被反复打开又合上信里说了一些话关于明天关于记忆关于遗忘但最后一行被水渍模糊了只剩下几个字看不清是道别还是承诺";
  textFont(font);
  textSize(cw * 0.7);
  textAlign(CENTER, CENTER);
  noStroke();
  fill(60, 55, 45, 200);
  let idx = 0;
  for (let r = 1; r < 8; r++) {
    for (let c = 0; c < cols; c++) {
      if (idx >= content.length) break;
      const x = mx + c * cw + cw/2;
      const y = my + r * ch + ch/2;
      text(content[idx], x, y);
      idx++;
    }
  }
  
  // A few water stains
  noStroke();
  const stains = [[3,4],[7,2],[10,6],[5,9],[1,5]];
  for (let [sc, sr] of stains) {
    const sx = mx + sc * cw + cw/2;
    const sy = my + sr * ch + ch/2;
    fill(180, 210, 230, 40);
    ellipse(sx, sy, cw*1.2, ch*1.2);
  }
}
</script>
</body></html>
