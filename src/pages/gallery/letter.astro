---
import Base from '../../layouts/Base.astro';
---
<Base title="信 · Letter">
  <article>
    <h1>信 · Letter</h1>
    <div class="article-content">
      <div id="letter-canvas" style="margin: 2rem 0; display: flex; justify-content: center;"></div>
      <p class="work-desc">醒来发现昨天的自己留了一封信，但笔迹不认识。</p>
      <p style="text-align: center; font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-muted);">
        点击画面，新的阅读轨迹开始生长。
      </p>
    </div>
  </article>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Liu+Jian+Mao+Cao&family=Ma+Shan+Zheng&display=swap" rel="stylesheet">

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.4/p5.min.js"></script>
  <script is:inline>
  (function() {
    // CONFIG — 参数集中管理（学思花）
    var CONFIG = {
      W: 580,
      H: 780,
      // 配色：临摹思花深底+浅字风格
      bgColor: [35, 30, 28],           // 深暖褐（不是纯黑）
      warmColor: [215, 200, 175, 200],  // 暖米色文字（原始/你以为认识的）
      coolColor: [140, 170, 210, 230],  // 冷蓝灰文字（揭露/真实笔迹）
      curveColor: [140, 170, 210, 15],  // 曲线痕迹（极淡，几乎隐形）
      // 文字
      text: '醒来发现昨天的自己留了一封信但笔迹不认识你试着读每个字都认得但连在一起又觉得陌生就像你明明记得这条路却怎么也走不到尽头信的最后写着别担心但你不知道是谁在安慰谁',
      warmFont: '"Ma Shan Zheng", cursive',
      coolFont: '"Liu Jian Mao Cao", cursive',
      fontSize: 22,
      lineHeight: 38,
      charSpacing: 28,
      marginX: 50,
      marginY: 60,
      // 曲线（线：阅读轨迹）
      curve: {
        growSpeed: 2,
        xDriftRange: [-0.8, 0.8],
        weightRange: [25, 40],       // 粗！形成面状蒙版，不是细线
        maxCurves: 15,
        spawnInterval: 90
      }
    };

    var curves = [];
    var charGrid = [];  // {x, y, char, warm: true/false}
    var warmLayer, coolLayer;

    new p5(function(p) {

      p.setup = function() {
        var canvas = p.createCanvas(CONFIG.W, CONFIG.H);
        canvas.parent('letter-canvas');
        p.pixelDensity(1);
        p.textAlign(p.CENTER, p.CENTER);
        p.noStroke();

        // 预渲染两层文字到离屏buffer
        warmLayer = p.createGraphics(CONFIG.W, CONFIG.H);
        coolLayer = p.createGraphics(CONFIG.W, CONFIG.H);
        warmLayer.pixelDensity(1);
        coolLayer.pixelDensity(1);

        // 暖层（楷书）——原始信
        warmLayer.background(CONFIG.bgColor);
        warmLayer.fill(CONFIG.warmColor[0], CONFIG.warmColor[1], CONFIG.warmColor[2], CONFIG.warmColor[3]);
        warmLayer.noStroke();
        warmLayer.textFont(CONFIG.warmFont);
        warmLayer.textSize(CONFIG.fontSize);
        warmLayer.textAlign(warmLayer.CENTER, warmLayer.CENTER);

        // 冷层（草书）——真实笔迹
        coolLayer.background(CONFIG.bgColor);
        coolLayer.fill(CONFIG.coolColor[0], CONFIG.coolColor[1], CONFIG.coolColor[2], CONFIG.coolColor[3]);
        coolLayer.noStroke();
        coolLayer.textFont(CONFIG.coolFont);
        coolLayer.textSize(CONFIG.fontSize + 4);  // 草书略大
        coolLayer.textAlign(coolLayer.CENTER, coolLayer.CENTER);

        // 填充文字——不是整齐网格，加一点随机偏移
        var fullText = CONFIG.text;
        var idx = 0;
        var y = CONFIG.marginY;
        while (y < CONFIG.H - CONFIG.marginY) {
          var x = CONFIG.marginX;
          // 每行起始位置微偏移
          x += (Math.random() - 0.5) * 8;
          while (x < CONFIG.W - CONFIG.marginX) {
            var ch = fullText[idx % fullText.length];
            // 位置微偏移（不整齐=手写感）
            var ox = (Math.random() - 0.5) * 4;
            var oy = (Math.random() - 0.5) * 4;
            warmLayer.text(ch, x + ox, y + oy);
            coolLayer.text(ch, x + ox + (Math.random()-0.5)*3, y + oy + (Math.random()-0.5)*3);
            charGrid.push({x: x+ox, y: y+oy, ch: ch});
            idx++;
            x += CONFIG.charSpacing + (Math.random() - 0.5) * 4;
          }
          y += CONFIG.lineHeight + (Math.random() - 0.5) * 6;
        }

        warmLayer.loadPixels();
        coolLayer.loadPixels();

        // 初始生成几条曲线
        for (var i = 0; i < 3; i++) {
          spawnCurve();
        }
      };

      function spawnCurve() {
        curves.push({
          points: [{
            x: Math.random() * (CONFIG.W - 100) + 50,
            y: -10
          }],
          speed: CONFIG.curve.growSpeed + Math.random() * 1.5,
          weight: CONFIG.curve.weightRange[0] + Math.random() * (CONFIG.curve.weightRange[1] - CONFIG.curve.weightRange[0]),
          noiseOff: Math.random() * 1000,
          maxLen: 600 + Math.random() * 400,
          growing: true
        });
      }

      p.draw = function() {
        // 从暖层开始（完整的信）
        p.image(warmLayer, 0, 0);
        p.loadPixels();

        // 更新曲线生长
        for (var ci = 0; ci < curves.length; ci++) {
          var c = curves[ci];
          if (!c.growing) continue;
          var last = c.points[c.points.length - 1];
          var angle = p.noise(c.noiseOff, last.y * 0.003) * p.TWO_PI;
          var dx = Math.cos(angle) * c.speed * 0.3;
          var dy = c.speed;
          var nx = last.x + dx;
          // 边界反弹
          if (nx < 30) { nx = 30; c.noiseOff += 0.5; }
          if (nx > CONFIG.W - 30) { nx = CONFIG.W - 30; c.noiseOff += 0.5; }
          c.points.push({x: nx, y: last.y + dy});
          if (c.points.length * c.speed > c.maxLen || last.y > CONFIG.H + 10) {
            c.growing = false;
          }
        }

        // 自动生成新曲线
        if (p.frameCount % CONFIG.curve.spawnInterval === 0 && curves.length < CONFIG.curve.maxCurves) {
          spawnCurve();
        }

        // 蒙版合成：曲线覆盖区域显示冷层
        // 用距离检测：每个像素如果接近任何曲线点，显示冷层
        // 优化：只检查曲线附近的区域
        coolLayer.loadPixels();

        for (var ci2 = 0; ci2 < curves.length; ci2++) {
          var c2 = curves[ci2];
          var hw = c2.weight / 2;
          for (var pi = 0; pi < c2.points.length; pi++) {
            var pt = c2.points[pi];
            var x0 = Math.max(0, Math.floor(pt.x - hw));
            var x1 = Math.min(CONFIG.W - 1, Math.ceil(pt.x + hw));
            var y0 = Math.max(0, Math.floor(pt.y - hw));
            var y1 = Math.min(CONFIG.H - 1, Math.ceil(pt.y + hw));
            for (var py = y0; py <= y1; py++) {
              for (var px = x0; px <= x1; px++) {
                var dist = Math.sqrt((px-pt.x)*(px-pt.x) + (py-pt.y)*(py-pt.y));
                if (dist < hw) {
                  var idx = (py * CONFIG.W + px) * 4;
                  // 渐变过渡：边缘混合
                  var blend = 1 - (dist / hw);
                  blend = blend * blend; // ease-in
                  p.pixels[idx]   = Math.round(p.pixels[idx]   * (1-blend) + coolLayer.pixels[idx]   * blend);
                  p.pixels[idx+1] = Math.round(p.pixels[idx+1] * (1-blend) + coolLayer.pixels[idx+1] * blend);
                  p.pixels[idx+2] = Math.round(p.pixels[idx+2] * (1-blend) + coolLayer.pixels[idx+2] * blend);
                }
              }
            }
          }
        }
        p.updatePixels();

        // 曲线痕迹（极淡的线——线元素）
        p.stroke(CONFIG.curveColor[0], CONFIG.curveColor[1], CONFIG.curveColor[2], CONFIG.curveColor[3]);
        p.strokeWeight(1);
        p.noFill();
        for (var ci3 = 0; ci3 < curves.length; ci3++) {
          var c3 = curves[ci3];
          if (c3.points.length < 2) continue;
          p.beginShape();
          p.curveVertex(c3.points[0].x, c3.points[0].y);
          for (var pi2 = 0; pi2 < c3.points.length; pi2++) {
            p.curveVertex(c3.points[pi2].x, c3.points[pi2].y);
          }
          p.curveVertex(c3.points[c3.points.length-1].x, c3.points[c3.points.length-1].y);
          p.endShape();
        }

        // 全部曲线停止生长后降帧率省资源
        var anyGrowing = false;
        for (var ci4 = 0; ci4 < curves.length; ci4++) {
          if (curves[ci4].growing) { anyGrowing = true; break; }
        }
        if (!anyGrowing) p.frameRate(2);
      };

      p.mousePressed = function() {
        if (p.mouseX > 0 && p.mouseX < CONFIG.W && p.mouseY > 0 && p.mouseY < CONFIG.H) {
          p.frameRate(60);
          curves.push({
            points: [{x: p.mouseX, y: Math.max(0, p.mouseY - 50)}],
            speed: CONFIG.curve.growSpeed + Math.random(),
            weight: CONFIG.curve.weightRange[0] + Math.random() * (CONFIG.curve.weightRange[1] - CONFIG.curve.weightRange[0]),
            noiseOff: Math.random() * 1000,
            maxLen: 400 + Math.random() * 300,
            growing: true
          });
        }
      };
    });
  })();
  </script>

  <style>
    .work-desc {
      text-align: center;
      font-style: italic;
      color: var(--text-muted);
      margin: 1rem 0;
    }
  </style>
</Base>
