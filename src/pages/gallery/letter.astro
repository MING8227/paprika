---
import Base from '../../layouts/Base.astro';
---

<Base title="信 · Letter">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.0/p5.min.js" is:inline></script>
  <script is:inline>
    const CONFIG = {
      canvas: { width: 580, height: 780 },
      grid: { cols: 14, rows: 20, marginX: 40, marginY: 40 },
      text: {
        content: "醒来发现昨天的自己留了一封信但笔迹不认识你试着读每个字都认得但连在一起又觉得陌生信的最后写着别担心但你不知道是谁在安慰谁",
        sampleSize: 72,
        displaySize: 18,
        color: [74, 69, 64],
        pointDensity: 0.15
      },
      paper: {
        bg: [245, 242, 235],
        lineColor: [0, 0, 0, 18],
        lineWeight: 0.4
      },
      damage: {
        driftMax: 12,
        driftSpeed: 0.02,
        fadeAlpha: 80,
        rustColor: [180, 75, 55],
        rustAlpha: 0.2,
        rustCount: 8
      },
      curve: {
        growSpeed: 1.5,
        xDriftScale: 0.004,
        weight: 60,
        spawnInterval: 200,
        maxCurves: 4,
        startYRange: [-30, 0]
      }
    };

    let sanShengFont;
    let charData = [];
    let curves = [];
    let lastSpawnFrame = -150;

    function preload() {
      sanShengFont = loadFont('/paprika/fonts/SanSheng-subset.ttf');
    }

    function setup() {
      pixelDensity(1);
      const canvas = createCanvas(CONFIG.canvas.width, CONFIG.canvas.height);
      canvas.parent(document.querySelector('main') || document.body);

      buildCharPoints();
      noStroke();
    }

    function buildCharPoints() {
      const { cols, rows, marginX, marginY } = CONFIG.grid;
      const cellW = (width - marginX * 2) / cols;
      const cellH = (height - marginY * 2) / rows;
      const content = CONFIG.text.content;
      const scale = CONFIG.text.displaySize / CONFIG.text.sampleSize;

      let idx = 0;
      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          const ch = content[idx % content.length];
          idx++;

          const cx = marginX + (c + 0.5) * cellW;
          const cy = marginY + (r + 0.5) * cellH;

          let rawPoints;
          try {
            rawPoints = sanShengFont.textToPoints(ch, 0, 0, CONFIG.text.sampleSize, {
              sampleFactor: CONFIG.text.pointDensity
            });
          } catch(e) {
            rawPoints = [];
          }

          if (rawPoints.length === 0) continue;

          // center the points
          let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
          for (let p of rawPoints) {
            if (p.x < minX) minX = p.x;
            if (p.x > maxX) maxX = p.x;
            if (p.y < minY) minY = p.y;
            if (p.y > maxY) maxY = p.y;
          }
          const offX = (minX + maxX) / 2;
          const offY = (minY + maxY) / 2;

          const points = rawPoints.map(p => ({
            homeX: cx + (p.x - offX) * scale,
            homeY: cy + (p.y - offY) * scale,
            x: cx + (p.x - offX) * scale,
            y: cy + (p.y - offY) * scale,
            drift: 0,
            noiseOff: random(1000),
            phase: random(TWO_PI)
          }));

          charData.push({ cx, cy, points, damaged: false });
        }
      }
    }

    function spawnCurve(sx, sy) {
      if (curves.length >= CONFIG.curve.maxCurves) return;
      curves.push({
        x: sx !== undefined ? sx : random(CONFIG.grid.marginX + 30, width - CONFIG.grid.marginX - 30),
        y: sy !== undefined ? sy : random(CONFIG.curve.startYRange[0], CONFIG.curve.startYRange[1]),
        noiseOff: random(1000),
        active: true
      });
    }

    function draw() {
      background(CONFIG.paper.bg[0], CONFIG.paper.bg[1], CONFIG.paper.bg[2]);

      drawGrid();

      // spawn curves
      if (frameCount - lastSpawnFrame >= CONFIG.curve.spawnInterval) {
        spawnCurve();
        lastSpawnFrame = frameCount;
      }

      // grow curves & affect nearby chars
      const halfW = CONFIG.curve.weight / 2;
      for (let cv of curves) {
        if (!cv.active) continue;
        const prevY = cv.y;
        cv.y += CONFIG.curve.growSpeed;
        cv.x += (noise(cv.noiseOff) - 0.5) * 2 * 8;
        cv.noiseOff += CONFIG.curve.xDriftScale * 60;

        if (cv.y > height + 20) {
          cv.active = false;
          continue;
        }

        // affect chars near this curve segment
        for (let cd of charData) {
          const dy = cv.y - cd.cy;
          const dx = cv.x - cd.cx;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < halfW) {
            const influence = 1 - dist / halfW;
            for (let pt of cd.points) {
              pt.drift = min(1, pt.drift + influence * 0.08);
            }
          }
        }
      }

      // draw rust spots (subtle, behind text)
      drawRust();

      // draw all char points
      const tc = CONFIG.text.color;
      const dm = CONFIG.damage;
      for (let cd of charData) {
        for (let pt of cd.points) {
          if (pt.drift > 0.01) {
            // drifting point
            const d = pt.drift;
            const nx = noise(pt.noiseOff, frameCount * dm.driftSpeed);
            const ny = noise(pt.noiseOff + 500, frameCount * dm.driftSpeed);
            pt.x = pt.homeX + (nx - 0.5) * 2 * dm.driftMax * d;
            pt.y = pt.homeY + (ny - 0.5) * 2 * dm.driftMax * d;

            const alpha = map(d, 0, 1, 255, dm.fadeAlpha);
            fill(tc[0], tc[1], tc[2], alpha);
            const sz = map(d, 0, 1, 2.2, 1.2);
            ellipse(pt.x, pt.y, sz, sz);
          } else {
            // solid point
            fill(tc[0], tc[1], tc[2], 240);
            ellipse(pt.x, pt.y, 2.2, 2.2);
          }
        }
      }
    }

    function drawGrid() {
      const { cols, rows, marginX, marginY, lineColor, lineWeight } = Object.assign({}, CONFIG.grid, CONFIG.paper);
      const cellW = (width - marginX * 2) / cols;
      const cellH = (height - marginY * 2) / rows;

      stroke(CONFIG.paper.lineColor[0], CONFIG.paper.lineColor[1], CONFIG.paper.lineColor[2], CONFIG.paper.lineColor[3]);
      strokeWeight(CONFIG.paper.lineWeight);

      for (let i = 0; i <= cols; i++) {
        const x = marginX + i * cellW;
        line(x, marginY, x, height - marginY);
      }
      for (let j = 0; j <= rows; j++) {
        const y = marginY + j * cellH;
        line(marginX, y, width - marginX, y);
      }
      noStroke();
    }

    function drawRust() {
      // static rust drawn with noise seed so consistent
      randomSeed(42);
      const rc = CONFIG.damage.rustColor;
      noStroke();
      for (let i = 0; i < CONFIG.damage.rustCount; i++) {
        fill(rc[0], rc[1], rc[2], CONFIG.damage.rustAlpha * 255);
        const rx = random(CONFIG.grid.marginX + 20, width - CONFIG.grid.marginX - 20);
        const ry = random(CONFIG.grid.marginY + 20, height - CONFIG.grid.marginY - 20);
        const rs = random(5, 15);
        ellipse(rx, ry, rs, rs);
      }
      randomSeed(millis());
    }

    function mousePressed() {
      if (mouseX >= 0 && mouseX <= width && mouseY >= 0 && mouseY <= height) {
        spawnCurve(mouseX, mouseY);
      }
    }
  </script>
</Base>
