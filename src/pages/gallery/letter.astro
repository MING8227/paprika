---
import Base from '../../layouts/Base.astro';
---

<Base title="信 · Letter">
  <div style="display:flex;justify-content:center;align-items:center;min-height:100vh;background:#1a1a1a;">
    <div id="canvas-container"></div>
  </div>

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.0/p5.min.js"></script>
  <script is:inline>
    let font;
    const W = 580, H = 780;
    const COLS = 18, ROWS = 24;
    const MARGIN_X = 30, MARGIN_Y = 30;
    const CELL_W = (W - MARGIN_X * 2) / COLS;
    const CELL_H = (H - MARGIN_Y * 2) / ROWS;

    const TEXT = "醒来发现昨天的自己留了一封信但笔迹不认识你试着读每个字都认得但连在一起又觉得陌生信的最后写着别担心但你不知道是谁在安慰谁";

    // Spring grid
    let nodes = [];
    let springs = [];

    // Water stain
    let stains = [];

    const STIFFNESS = 0.03;
    const DAMPING = 0.85;
    const REPULSE_STRENGTH = 3.5;

    function preload() {
      font = loadFont('/paprika/fonts/PingFangSanShengTi-2.ttf');
    }

    function setup() {
      let cnv = createCanvas(W, H);
      cnv.parent('canvas-container');
      colorMode(HSB, 360, 100, 100, 100);
      textFont(font);
      textAlign(CENTER, CENTER);
      textSize(CELL_W * 0.65);

      // Create grid nodes (COLS+1 x ROWS+1 for grid lines)
      for (let r = 0; r <= ROWS; r++) {
        nodes[r] = [];
        for (let c = 0; c <= COLS; c++) {
          let rx = MARGIN_X + c * CELL_W;
          let ry = MARGIN_Y + r * CELL_H;
          nodes[r][c] = {
            x: rx, y: ry,
            restX: rx, restY: ry,
            vx: 0, vy: 0
          };
        }
      }

      // Create springs (horizontal + vertical)
      for (let r = 0; r <= ROWS; r++) {
        for (let c = 0; c <= COLS; c++) {
          if (c < COLS) springs.push({ a: nodes[r][c], b: nodes[r][c + 1], restLen: CELL_W });
          if (r < ROWS) springs.push({ a: nodes[r][c], b: nodes[r + 1][c], restLen: CELL_H });
        }
      }

      // Initial water stain - center-upper
      stains.push({ x: W * 0.52, y: H * 0.32, birth: frameCount, maxR: 70 });
    }

    function draw() {
      background(0, 0, 96); // clean light grey #f2f2f2

      let t = frameCount;

      // Update stain radii
      for (let s of stains) {
        let age = t - s.birth;
        let progress = 1 - Math.pow(0.97, age); // easeOut
        s.currentR = s.maxR * progress;
      }

      // Apply forces to nodes
      for (let r = 0; r <= ROWS; r++) {
        for (let c = 0; c <= COLS; c++) {
          let n = nodes[r][c];
          // Anchor spring (return to rest)
          let ax = (n.restX - n.x) * 0.01;
          let ay = (n.restY - n.y) * 0.01;
          n.vx += ax;
          n.vy += ay;

          // Water stain repulsion
          for (let s of stains) {
            let dx = n.x - s.x;
            let dy = n.y - s.y;
            let dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < s.currentR && dist > 1) {
              let force = REPULSE_STRENGTH * (1 - dist / s.currentR);
              n.vx += (dx / dist) * force;
              n.vy += (dy / dist) * force;
            }
          }
        }
      }

      // Spring forces
      for (let sp of springs) {
        let dx = sp.b.x - sp.a.x;
        let dy = sp.b.y - sp.a.y;
        let dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 0.1) continue;
        let diff = (dist - sp.restLen) / dist;
        let fx = dx * diff * STIFFNESS;
        let fy = dy * diff * STIFFNESS;
        sp.a.vx += fx;
        sp.a.vy += fy;
        sp.b.vx -= fx;
        sp.b.vy -= fy;
      }

      // Integrate
      for (let r = 0; r <= ROWS; r++) {
        for (let c = 0; c <= COLS; c++) {
          let n = nodes[r][c];
          n.vx *= DAMPING;
          n.vy *= DAMPING;
          n.x += n.vx;
          n.y += n.vy;
        }
      }

      // Draw water stains
      noStroke();
      for (let s of stains) {
        if (s.currentR < 1) continue;
        // Edge ring - pepper red
        for (let i = 5; i >= 0; i--) {
          let rr = s.currentR + i * 3;
          fill(5, 50, 55, 3);
          ellipse(s.x, s.y, rr * 2, rr * 2);
        }
        // Main stain - blue
        for (let i = 3; i >= 0; i--) {
          let rr = s.currentR - i * 5;
          if (rr < 0) continue;
          fill(210, 30, 75, 8);
          ellipse(s.x, s.y, rr * 2, rr * 2);
        }
      }

      // Draw grid lines
      stroke(0, 0, 70, 20);
      strokeWeight(0.5);
      for (let r = 0; r <= ROWS; r++) {
        for (let c = 0; c < COLS; c++) {
          line(nodes[r][c].x, nodes[r][c].y, nodes[r][c + 1].x, nodes[r][c + 1].y);
        }
      }
      for (let r = 0; r < ROWS; r++) {
        for (let c = 0; c <= COLS; c++) {
          line(nodes[r][c].x, nodes[r][c].y, nodes[r + 1][c].x, nodes[r + 1][c].y);
        }
      }

      // Draw text in cells
      noStroke();
      fill(0, 0, 0); // will set per char
      let charIdx = 0;
      for (let r = 0; r < ROWS; r++) {
        for (let c = 0; c < COLS; c++) {
          // Cell center = average of 4 corner nodes
          let tl = nodes[r][c];
          let tr = nodes[r][c + 1];
          let bl = nodes[r + 1][c];
          let br = nodes[r + 1][c + 1];
          let cx = (tl.x + tr.x + bl.x + br.x) / 4;
          let cy = (tl.y + tr.y + bl.y + br.y) / 4;

          let ch = TEXT[charIdx % TEXT.length];
          charIdx++;

          // Check if inside stain - fade ink
          let inStain = false;
          for (let s of stains) {
            let d = dist(cx, cy, s.x, s.y);
            if (d < s.currentR * 0.7) {
              inStain = true;
              break;
            }
          }

          if (inStain) {
            fill(210, 15, 55, 50); // faded blue-gray
          } else {
            fill(35, 15, 29, 85); // warm gray ink #4a4540
          }

          push();
          translate(cx, cy);
          // Slight rotation from grid distortion
          let angle = atan2(tr.y - tl.y, tr.x - tl.x);
          rotate(angle);
          text(ch, 0, 0);
          pop();
        }
      }
    }

    function mousePressed() {
      if (mouseX > 0 && mouseX < W && mouseY > 0 && mouseY < H) {
        stains.push({ x: mouseX, y: mouseY, birth: frameCount, maxR: 50 + random(30), currentR: 0 });
      }
    }
  </script>
</Base>
