---
import Base from '../../layouts/Base.astro';
---
<Base title="信 · Letter">
  <article>
    <h1>信 · Letter</h1>
    <div class="article-meta">2026.03.19 · Wednesday</div>
    <div class="article-content">
      <p>写给明天的自己——但明天的自己不认识这些字。</p>
      <div id="letter-canvas" style="margin: 2.5rem 0; display: flex; justify-content: center;"></div>
      <p style="text-align: center; font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-muted);">
        点击画布，试着重新认出这些字
      </p>
      <hr style="margin:3rem 0;opacity:0.2">
      <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted);">
        语义饱和——盯着一个字看久了，它就不像那个字了。不是字变了，是你和它之间的连接断了。
      </p>
    </div>
  </article>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.4/p5.min.js"></script>
  <script is:inline>
    (function() {
      const CONFIG = {
        W: 580,
        H: 580,
        bgColor: '#f5f0e8',
        inkColor: '#2a2a2a',
        // Letter content
        text: '昨天的事情我想了很久。有些话当时没说出口，不是不想说，是不知道怎么开口。你醒来的时候可能已经不记得了，但我还是想写下来。其实我不确定你还认不认得这些字。我写的时候手在抖，不是因为冷，是因为知道明天的你不记得今天的事。每次都是这样。我写了很多，你读到的只是碎片。也许这就够了。也许连碎片都　　太多了。我不知道　　　　',
        // Layout
        marginLeft: 70,
        marginTop: 100,
        lineHeight: 52,
        charSize: 24,
        charsPerLine: 14,
        // Handwriting jitter (initial, static per char)
        jitterX: 1.2,
        jitterY: 1.0,
        jitterRot: 0.02,
        // Deformation
        deformSpeed: 0.00003,    // very slow
        rippleSpeed: 0.008,      // how fast ripple expands from center
        maxDeformX: 6,
        maxDeformY: 4,
        maxDeformRot: 0.12,
        maxDeformScale: 0.15,
        // Click reset
        resetStrength: 0.7,      // how much deformation is removed per click (decays)
        resetDecay: 0.82,        // each click is less effective
        // Paper texture
        textureCount: 4000,
      };

      let chars = [];
      let clickCount = 0;
      let resetEffectiveness = 1.0;
      let startTime;
      let paperTexture = [];

      function setup() {
        let cnv = createCanvas(CONFIG.W, CONFIG.H);
        cnv.parent('letter-canvas');
        textFont('serif');
        textSize(CONFIG.charSize);
        textAlign(LEFT, TOP);
        startTime = millis();

        // Generate paper texture spots
        for (let i = 0; i < CONFIG.textureCount; i++) {
          paperTexture.push({
            x: random(CONFIG.W),
            y: random(CONFIG.H),
            sz: random(1, 3),
            alpha: random(8, 25)
          });
        }

        // Parse text into character objects
        let col = 0, row = 0;
        for (let i = 0; i < CONFIG.text.length; i++) {
          let ch = CONFIG.text[i];
          if (ch === '\n' || col >= CONFIG.charsPerLine) {
            col = 0;
            row++;
          }
          if (ch === '\n') continue;

          // Punctuation that shouldn't start a line — push to previous line end
          let x = CONFIG.marginLeft + col * (CONFIG.charSize + 10);
          let y = CONFIG.marginTop + row * CONFIG.lineHeight;

          // Distance from center for ripple
          let cx = CONFIG.W / 2, cy = CONFIG.H / 2;
          let distFromCenter = dist(x, y, cx, cy);

          chars.push({
            ch: ch,
            baseX: x,
            baseY: y,
            // Static handwriting jitter (unique per char, never changes)
            handX: random(-CONFIG.jitterX, CONFIG.jitterX),
            handY: random(-CONFIG.jitterY, CONFIG.jitterY),
            handRot: random(-CONFIG.jitterRot, CONFIG.jitterRot),
            // Deformation state
            deformX: 0,
            deformY: 0,
            deformRot: 0,
            deformScale: 0,
            // Baseline offset (accumulates with clicks, never fully resets)
            baselineX: 0,
            baselineY: 0,
            baselineRot: 0,
            baselineScale: 0,
            // Ripple
            distFromCenter: distFromCenter,
            // Noise seeds
            seedX: random(1000),
            seedY: random(1000),
            seedR: random(1000),
            seedS: random(1000),
          });

          col++;
        }
      }

      function draw() {
        // Paper background
        background(CONFIG.bgColor);

        // Paper texture
        noStroke();
        for (let t of paperTexture) {
          fill(180, 170, 155, t.alpha);
          ellipse(t.x, t.y, t.sz);
        }

        // Faint ruled lines
        stroke(200, 190, 170, 40);
        strokeWeight(0.5);
        for (let row = 0; row < 10; row++) {
          let ly = CONFIG.marginTop + row * CONFIG.lineHeight + CONFIG.charSize + 8;
          line(CONFIG.marginLeft - 10, ly, CONFIG.W - CONFIG.marginLeft + 10, ly);
        }

        // Elapsed time
        let elapsed = (millis() - startTime) / 1000; // seconds

        // Draw characters
        noStroke();
        fill(CONFIG.inkColor);
        textSize(CONFIG.charSize);

        for (let c of chars) {
          // Ripple: deformation starts from center, expands outward
          let ripplePhase = elapsed * CONFIG.rippleSpeed - c.distFromCenter * 0.003;
          let deformAmount = max(0, ripplePhase);
          // Smooth ramp up, cap at 1
          deformAmount = min(deformAmount, 1);
          // Additional slow growth over time
          let timeGrowth = elapsed * CONFIG.deformSpeed;

          // Noise-driven deformation
          let t = elapsed * 0.05;
          let dx = (noise(c.seedX, t) - 0.5) * 2 * CONFIG.maxDeformX * deformAmount * (1 + timeGrowth);
          let dy = (noise(c.seedY, t) - 0.5) * 2 * CONFIG.maxDeformY * deformAmount * (1 + timeGrowth);
          let dr = (noise(c.seedR, t) - 0.5) * 2 * CONFIG.maxDeformRot * deformAmount * (1 + timeGrowth);
          let ds = (noise(c.seedS, t) - 0.5) * 2 * CONFIG.maxDeformScale * deformAmount * (1 + timeGrowth);

          c.deformX = dx;
          c.deformY = dy;
          c.deformRot = dr;
          c.deformScale = ds;

          // Final position = base + handwriting jitter + baseline drift + deformation
          let finalX = c.baseX + c.handX + c.baselineX + c.deformX;
          let finalY = c.baseY + c.handY + c.baselineY + c.deformY;
          let finalRot = c.handRot + c.baselineRot + c.deformRot;
          let finalScale = 1 + c.baselineScale + c.deformScale;

          push();
          translate(finalX + CONFIG.charSize / 2, finalY + CONFIG.charSize / 2);
          rotate(finalRot);
          scale(finalScale);
          // Slight opacity variation for ink feel
          let inkAlpha = map(noise(c.seedX * 2, c.seedY * 2), 0, 1, 180, 255);
          fill(42, 42, 42, inkAlpha);
          text(c.ch, -CONFIG.charSize / 2, -CONFIG.charSize / 2);
          pop();
        }

        // Signature area — faint, bottom right
        push();
        fill(42, 42, 42, 60);
        textSize(14);
        textAlign(RIGHT, BOTTOM);
        text('昨天的我', CONFIG.W - CONFIG.marginLeft, CONFIG.H - 50);
        pop();
      }

      function mousePressed() {
        // Check click is on canvas
        if (mouseX < 0 || mouseX > CONFIG.W || mouseY < 0 || mouseY > CONFIG.H) return;

        clickCount++;
        let effectiveness = resetEffectiveness * pow(CONFIG.resetDecay, clickCount - 1);

        // "Re-recognize": push current deformation partially into baseline, reset deform
        for (let c of chars) {
          // The part that doesn't get reset becomes permanent baseline
          let keepRatio = 1 - effectiveness * CONFIG.resetStrength;
          c.baselineX += c.deformX * keepRatio;
          c.baselineY += c.deformY * keepRatio;
          c.baselineRot += c.deformRot * keepRatio;
          c.baselineScale += c.deformScale * keepRatio;
        }

        // Reset time to restart ripple, but baseline persists
        startTime = millis();
      }

      window.setup = setup;
      window.draw = draw;
      window.mousePressed = mousePressed;
    })();
  </script>
</Base>
