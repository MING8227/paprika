---
import Base from '../../layouts/Base.astro';
---

<Base title="信 · Letter">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.0/p5.min.js" is:inline></script>
  <script is:inline>
    const CONFIG = {
      canvas: { width: 580, height: 780 },
      grid: { cols: 18, rows: 24, marginX: 30, marginY: 30, lineColor: [0,0,0,20], lineWeight: 0.5 },
      text: {
        content: "醒来发现昨天的自己留了一封信但笔迹不认识你试着读每个字都认得但连在一起又觉得陌生信的最后写着别担心但你不知道是谁在安慰谁",
        color: [74,69,64],
        size: 16
      },
      damage: {
        textAlpha: 0.12,
        textOffset: 6,
        blur: 3,
        bgColor: '#e4eaf2',
        gridBreakChance: 0.55,
        rustColor: [190, 75, 55],
        rustAlpha: 0.35,
        rustCount: 35
      },
      curve: {
        startYRange: [-20, 0],
        growthSpeedRange: [4, 8],
        xDriftScale: 0.003,
        maxLengthRange: [600, 900],
        weight: 30,
        spawnInterval: 40,
        maxCurves: 15
      }
    };

    let sanShengFont;
    let cleanLayer, damagedLayer, maskLayer;
    let curves = [];
    let lastSpawnFrame = 0;

    function preload() {
      sanShengFont = loadFont('/paprika/fonts/PingFangSanShengTi-2.ttf');
    }

    function setup() {
      const canvas = createCanvas(CONFIG.canvas.width, CONFIG.canvas.height);
      canvas.parent(document.querySelector('main') || document.body);

      cleanLayer = createGraphics(width, height);
      damagedLayer = createGraphics(width, height);
      maskLayer = createGraphics(width, height);

      drawCleanLayer();
      drawDamagedLayer();

      maskLayer.background(0);
    }

    function drawGrid(g, breakChance) {
      const { cols, rows, marginX, marginY, lineColor, lineWeight } = CONFIG.grid;
      const cellW = (width - marginX * 2) / cols;
      const cellH = (height - marginY * 2) / rows;

      g.stroke(lineColor[0], lineColor[1], lineColor[2], lineColor[3]);
      g.strokeWeight(lineWeight);

      for (let i = 0; i <= cols; i++) {
        if (breakChance > 0 && random() < breakChance) continue;
        const x = marginX + i * cellW;
        g.line(x, marginY, x, height - marginY);
      }
      for (let j = 0; j <= rows; j++) {
        if (breakChance > 0 && random() < breakChance) continue;
        const y = marginY + j * cellH;
        g.line(marginX, y, width - marginX, y);
      }
    }

    function drawTextContent(g, col, alpha, offset) {
      const { cols, rows, marginX, marginY } = CONFIG.grid;
      const cellW = (width - marginX * 2) / cols;
      const cellH = (height - marginY * 2) / rows;
      const content = CONFIG.text.content;

      g.textFont(sanShengFont);
      g.textSize(CONFIG.text.size);
      g.textAlign(CENTER, CENTER);
      g.noStroke();

      let idx = 0;
      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          const ch = content[idx % content.length];
          idx++;
          const x = marginX + (c + 0.5) * cellW + (offset ? random(-offset, offset) : 0);
          const y = marginY + (r + 0.5) * cellH + (offset ? random(-offset, offset) : 0);
          if (alpha < 1) {
            g.fill(col[0], col[1], col[2], alpha * 255);
          } else {
            g.fill(col[0], col[1], col[2]);
          }
          g.text(ch, x, y);
        }
      }
    }

    function drawCleanLayer() {
      cleanLayer.background('#f5f5f5');
      drawGrid(cleanLayer, 0);
      drawTextContent(cleanLayer, CONFIG.text.color, 1, 0);
    }

    function drawDamagedLayer() {
      damagedLayer.background(CONFIG.damage.bgColor);
      drawGrid(damagedLayer, CONFIG.damage.gridBreakChance);
      drawTextContent(damagedLayer, CONFIG.text.color, CONFIG.damage.textAlpha, CONFIG.damage.textOffset);

      // rust spots
      damagedLayer.noStroke();
      const rc = CONFIG.damage.rustColor;
      for (let i = 0; i < CONFIG.damage.rustCount; i++) {
        damagedLayer.fill(rc[0], rc[1], rc[2], CONFIG.damage.rustAlpha * 255);
        const rx = random(CONFIG.grid.marginX, width - CONFIG.grid.marginX);
        const ry = random(CONFIG.grid.marginY, height - CONFIG.grid.marginY);
        const rs = random(8, 25);
        damagedLayer.ellipse(rx, ry, rs, rs);
      }

      damagedLayer.filter(BLUR, CONFIG.damage.blur);
    }

    function spawnCurve(startX, startY) {
      if (curves.length >= CONFIG.curve.maxCurves) return;
      const cc = CONFIG.curve;
      curves.push({
        x: startX !== undefined ? startX : random(CONFIG.grid.marginX, width - CONFIG.grid.marginX),
        y: startY !== undefined ? startY : random(cc.startYRange[0], cc.startYRange[1]),
        noiseOff: random(1000),
        speed: random(cc.growthSpeedRange[0], cc.growthSpeedRange[1]),
        maxLen: random(cc.maxLengthRange[0], cc.maxLengthRange[1]),
        traveled: 0
      });
    }

    function draw() {
      // spawn new curves
      if (frameCount - lastSpawnFrame >= CONFIG.curve.spawnInterval) {
        spawnCurve();
        lastSpawnFrame = frameCount;
      }

      // grow curves on mask
      for (let c of curves) {
        if (c.traveled >= c.maxLen) continue;
        const ease = 1 - (c.traveled / c.maxLen);
        const step = c.speed * ease + 0.3;
        const prevX = c.x;
        const prevY = c.y;
        c.x += (noise(c.noiseOff) - 0.5) * 2 * 20;
        c.y += step;
        c.noiseOff += CONFIG.curve.xDriftScale * 100;
        c.traveled += step;

        maskLayer.stroke(255);
        maskLayer.strokeWeight(CONFIG.curve.weight);
        maskLayer.line(prevX, prevY, c.x, c.y);
      }

      // composite
      image(cleanLayer, 0, 0);

      // mask damaged layer
      let dmg = damagedLayer.get();
      let msk = maskLayer.get();
      dmg.mask(msk);
      image(dmg, 0, 0);
    }

    function mousePressed() {
      if (mouseX >= 0 && mouseX <= width && mouseY >= 0 && mouseY <= height) {
        spawnCurve(mouseX, mouseY);
      }
    }
  </script>
</Base>
