---
import Base from '../../layouts/Base.astro';
---

<Base title="信 · Letter">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.0/p5.min.js" is:inline></script>
  <script is:inline>
    const CONFIG = {
      canvas: { width: 580, height: 780 },
      grid: { cols: 14, rows: 20, marginX: 40, marginY: 40 },
      text: {
        content: "醒来发现昨天的自己留了一封信但笔迹不认识你试着读每个字都认得但连在一起又觉得陌生信的最后写着别担心但你不知道是谁在安慰谁",
        sampleSize: 72,
        displaySize: 18,
        color: [74, 69, 64],
        pointDensity: 0.18
      },
      paper: {
        bg: [250, 250, 252],
        lineColor: [120, 160, 155, 180],
        lineWeight: 0.8
      },
      damage: {
        driftMax: 12,
        driftSpeed: 0.008,
        fadeAlpha: 80,
        rustColor: [180, 75, 55],
        rustAlpha: 0.2,
        rustCount: 0
      },
      rain: {
        initialInterval: 18,
        minInterval: 8,
        rampDrops: 3,
        wetnessPerDrop: 0.8,
        diffusionRate: 0.0008,
        maxWetCells: 6
      },
      colorInherit: {
        baseColor: [74, 69, 64],
        warmColor: [180, 75, 55],
        driftStart: 0.05
      },
      gridDamage: {
        radius: 50,
        warpAmp: 22,
        breakGap: 8,
        offsetMax: 5
      },
      visualWeight: {
        pristine:  { size: 0.4, alpha: 180 },
        eroding:   { sizeMin: 0.4, sizeMax: 0.6, alphaMin: 60, alphaMax: 180, driftRange: [0.01, 0.5] },
        eroded:    { sizeMin: 0.6, sizeMax: 1.0, alphaMin: 20,  alphaMax: 60, driftThreshold: 0.5 }
      }
    };

    let sanShengFont;
    let charData = [];
    // Raindrop matrix: wetGrid[row][col] = 0..1
    let wetGrid = [];
    let wetAge = []; // frames since cell became wet
    let dropCount = 0;
    let lastDropFrame = -100;

    function preload() {
      sanShengFont = loadFont('/paprika/fonts/SanSheng-subset.ttf');
    }

    function setup() {
      pixelDensity(1);
      const canvas = createCanvas(CONFIG.canvas.width, CONFIG.canvas.height);
      canvas.parent(document.querySelector('main') || document.body);

      initWetGrid();
      buildCharPoints();
      noStroke();
    }

    function initWetGrid() {
      const { rows, cols } = CONFIG.grid;
      wetGrid = [];
      wetAge = []; // frames since this cell got wet
      for (let r = 0; r < rows; r++) {
        wetGrid[r] = new Float32Array(cols);
        wetAge[r] = new Float32Array(cols);
      }
      dropCount = 0;
      lastDropFrame = -100;
    }

    function buildCharPoints() {
      const { cols, rows, marginX, marginY } = CONFIG.grid;
      const cellW = (width - marginX * 2) / cols;
      const cellH = (height - marginY * 2) / rows;
      const content = CONFIG.text.content;
      const scale = CONFIG.text.displaySize / CONFIG.text.sampleSize;

      charData = [];
      let idx = 0;
      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          const ch = content[idx % content.length];
          idx++;

          const cx = marginX + (c + 0.5) * cellW;
          const cy = marginY + (r + 0.5) * cellH;

          let rawPoints;
          try {
            rawPoints = sanShengFont.textToPoints(ch, 0, 0, CONFIG.text.sampleSize, {
              sampleFactor: CONFIG.text.pointDensity
            });
          } catch(e) {
            rawPoints = [];
          }

          if (rawPoints.length === 0) continue;

          let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
          for (let p of rawPoints) {
            if (p.x < minX) minX = p.x;
            if (p.x > maxX) maxX = p.x;
            if (p.y < minY) minY = p.y;
            if (p.y > maxY) maxY = p.y;
          }
          const offX = (minX + maxX) / 2;
          const offY = (minY + maxY) / 2;

          const points = rawPoints.map(p => ({
            homeX: cx + (p.x - offX) * scale,
            homeY: cy + (p.y - offY) * scale,
            x: cx + (p.x - offX) * scale,
            y: cy + (p.y - offY) * scale,
            drift: 0,
            noiseOff: random(1000),
            phase: random(TWO_PI)
          }));

          charData.push({ cx, cy, row: r, col: c, points, char: ch });
        }
      }
    }

    // ---- Raindrop system ----

    function getDropInterval() {
      const { initialInterval, minInterval, rampDrops } = CONFIG.rain;
      const t = constrain(dropCount / rampDrops, 0, 1);
      return lerp(initialInterval, minInterval, t);
    }

    function spawnRaindrop() {
      const { rows, cols } = CONFIG.grid;
      let wetCount = 0;
      for (let r = 0; r < rows; r++)
        for (let c = 0; c < cols; c++)
          if (wetGrid[r][c] > 0.05) wetCount++;
      if (wetCount >= CONFIG.rain.maxWetCells) return;

      // Zone-based rotation: divide grid into 3x3 zones, cycle through them
      const zoneRows = 3, zoneCols = 3;
      const zoneIdx = dropCount % (zoneRows * zoneCols);
      const zr = Math.floor(zoneIdx / zoneCols);
      const zc = zoneIdx % zoneCols;
      const rStart = Math.floor(zr * rows / zoneRows);
      const rEnd = Math.floor((zr + 1) * rows / zoneRows);
      const cStart = Math.floor(zc * cols / zoneCols);
      const cEnd = Math.floor((zc + 1) * cols / zoneCols);

      // Collect dry cells in this zone
      let candidates = [];
      for (let r = rStart; r < rEnd; r++)
        for (let c = cStart; c < cEnd; c++)
          if (wetGrid[r][c] < 0.02) candidates.push([r, c]);

      // Fallback: any dry cell anywhere
      if (candidates.length === 0) {
        for (let r = 0; r < rows; r++)
          for (let c = 0; c < cols; c++)
            if (wetGrid[r][c] < 0.02) candidates.push([r, c]);
      }
      if (candidates.length === 0) return;

      const pick = candidates[Math.floor(random(candidates.length))];
      wetGrid[pick[0]][pick[1]] = min(1, wetGrid[pick[0]][pick[1]] + CONFIG.rain.wetnessPerDrop);
      wetAge[pick[0]][pick[1]] = 0; // just dropped — fresh
      dropCount++;
    }

    function diffuseWetness() {
      const { rows, cols } = CONFIG.grid;
      const rate = CONFIG.rain.diffusionRate;
      // Accumulate deltas to avoid order-dependent diffusion
      const deltas = [];
      for (let r = 0; r < rows; r++) {
        deltas[r] = new Float32Array(cols);
      }
      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          const w = wetGrid[r][c];
          if (w < 0.01) continue;
          const spread = w * rate;
          if (r > 0)        deltas[r-1][c] += spread;
          if (r < rows - 1) deltas[r+1][c] += spread;
          if (c > 0)        deltas[r][c-1] += spread;
          if (c < cols - 1) deltas[r][c+1] += spread;
        }
      }
      for (let r = 0; r < rows; r++)
        for (let c = 0; c < cols; c++)
          wetGrid[r][c] = min(1, wetGrid[r][c] + deltas[r][c]);
    }

    // Bilinear interpolation of wetness at pixel position
    function getWetnessAt(px, py) {
      const { cols, rows, marginX, marginY } = CONFIG.grid;
      const cellW = (width - marginX * 2) / cols;
      const cellH = (height - marginY * 2) / rows;
      // Convert pixel to continuous grid coords
      const gc = (px - marginX) / cellW - 0.5;
      const gr = (py - marginY) / cellH - 0.5;
      const c0 = Math.floor(gc), r0 = Math.floor(gr);
      const fc = gc - c0, fr = gr - r0;

      let total = 0;
      for (let dr = 0; dr <= 1; dr++) {
        for (let dc = 0; dc <= 1; dc++) {
          const rr = r0 + dr, cc = c0 + dc;
          if (rr >= 0 && rr < rows && cc >= 0 && cc < cols) {
            const wr = dr === 0 ? (1 - fr) : fr;
            const wc = dc === 0 ? (1 - fc) : fc;
            total += wetGrid[rr][cc] * wr * wc;
          }
        }
      }
      return total;
    }

    // ---- Draw ----

    function draw() {
      background(CONFIG.paper.bg[0], CONFIG.paper.bg[1], CONFIG.paper.bg[2]);

      drawPaperEdge();

      // Spawn raindrops
      const interval = getDropInterval();
      if (frameCount - lastDropFrame >= interval) {
        spawnRaindrop();
        lastDropFrame = frameCount;
      }

      // Diffuse wetness
      diffuseWetness();

      // Age wet cells: wetness fades over time (drops start deep, fade lighter)
      const { rows, cols } = CONFIG.grid;
      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          if (wetGrid[r][c] > 0.01) {
            wetAge[r][c]++;
            // Very slow fade: ~60 seconds for a drop to fully dry
            wetGrid[r][c] = max(0, wetGrid[r][c] - 0.0002);
          }
        }
      }

      drawWaterStains();
      drawGrid();

      // Chars drift only where directly hit
      for (let cd of charData) {
        const w = wetGrid[cd.row] ? wetGrid[cd.row][cd.col] : 0;
        if (w > 0.35) {
          for (let pt of cd.points) {
            pt.drift = min(1, pt.drift + w * 0.025);
          }
        }
      }

      // Draw all chars
      const base = CONFIG.colorInherit.baseColor;
      const warm = CONFIG.colorInherit.warmColor;
      const dm = CONFIG.damage;
      const vw = CONFIG.visualWeight;

      for (let cd of charData) {
        let maxDrift = 0;
        for (let pt of cd.points) {
          if (pt.drift > maxDrift) maxDrift = pt.drift;
        }

        if (maxDrift <= 0.01) {
          // PRISTINE
          const inf = getWetnessAt(cd.cx, cd.cy);
          let drawX = cd.cx;
          let drawY = cd.cy;
          if (inf > 0.05) {
            const warpX = (noise(cd.cx * 0.03, cd.cy * 0.03) - 0.5) * 2 * inf * 8;
            const warpY = (noise(cd.cx * 0.03 + 200, cd.cy * 0.03 + 200) - 0.5) * 2 * inf * 8;
            drawX += warpX;
            drawY += warpY;
          }
          noStroke();
          fill(base[0], base[1], base[2], vw.pristine.alpha);
          textFont(sanShengFont);
          textSize(CONFIG.text.displaySize);
          textAlign(CENTER, CENTER);
          text(cd.char, drawX, drawY);
        } else {
          // ERODING/ERODED
          for (let pt of cd.points) {
            if (pt.drift > 0.01) {
              const nx = noise(pt.noiseOff, frameCount * dm.driftSpeed);
              const ny = noise(pt.noiseOff + 500, frameCount * dm.driftSpeed);
              pt.x = pt.homeX + (nx - 0.5) * 2 * dm.driftMax * pt.drift;
              pt.y = pt.homeY + (ny - 0.5) * 2 * dm.driftMax * pt.drift;
            }
          }

          noFill();
          const pts = cd.points;
          for (let i = 0; i < pts.length - 1; i++) {
            const pt = pts[i];
            const pt2 = pts[i + 1];
            const d = max(pt.drift, pt2.drift);

            const gap = dist(pt.x, pt.y, pt2.x, pt2.y);
            if (gap > 8) continue;

            const colorT = constrain(map(d, CONFIG.colorInherit.driftStart, 1, 0, 1), 0, 1);
            const cr = lerp(base[0], warm[0], colorT);
            const cg = lerp(base[1], warm[1], colorT);
            const cb = lerp(base[2], warm[2], colorT);

            if (d > vw.eroded.driftThreshold) {
              const t = constrain(map(d, 0.5, 1, 0, 1), 0, 1);
              const alpha = lerp(vw.eroded.alphaMax, vw.eroded.alphaMin, t);
              const sw = lerp(vw.eroded.sizeMin, vw.eroded.sizeMax, t);
              if ((pt.noiseOff * 7) % 1 < 0.7) {
                stroke(cr, cg, cb, alpha);
                strokeWeight(sw);
                line(pt.x, pt.y, pt2.x, pt2.y);
              }
            } else if (d > 0.01) {
              const t = constrain(map(d, vw.eroding.driftRange[0], vw.eroding.driftRange[1], 0, 1), 0, 1);
              const alpha = lerp(vw.eroding.alphaMax, vw.eroding.alphaMin, t);
              const sw = lerp(vw.eroding.sizeMin, vw.eroding.sizeMax, t);
              stroke(cr, cg, cb, alpha);
              strokeWeight(sw);
              line(pt.x, pt.y, pt2.x, pt2.y);
            } else {
              stroke(base[0], base[1], base[2], vw.pristine.alpha);
              strokeWeight(vw.pristine.size);
              line(pt.x, pt.y, pt2.x, pt2.y);
            }
          }
        }
      }
      noStroke();
      restorePaperEdge();
    }

    function drawPaperEdge() {
      const bg = CONFIG.paper.bg;
      const mx = CONFIG.grid.marginX;
      const my = CONFIG.grid.marginY;
      const pw = width - mx * 2;
      const ph = height - my * 2;
      const amp = 7;
      const noiseScale = 0.015;
      const edgeSteps = 120;

      let paperVerts = [];

      for (let i = 0; i <= edgeSteps; i++) {
        const t = i / edgeSteps;
        const x = mx + t * pw;
        const y = my + (noise(x * noiseScale, 0) - 0.5) * 2 * amp;
        paperVerts.push({ x, y });
      }
      for (let i = 1; i <= edgeSteps; i++) {
        const t = i / edgeSteps;
        const x = mx + pw + (noise(1000, t * ph * noiseScale) - 0.5) * 2 * amp;
        const y = my + t * ph;
        paperVerts.push({ x, y });
      }
      for (let i = 1; i <= edgeSteps; i++) {
        const t = i / edgeSteps;
        const x = mx + pw - t * pw;
        const y = my + ph + (noise(x * noiseScale, 2000) - 0.5) * 2 * amp;
        paperVerts.push({ x, y });
      }
      for (let i = 1; i < edgeSteps; i++) {
        const t = i / edgeSteps;
        const x = mx + (noise(3000, t * ph * noiseScale) - 0.5) * 2 * amp;
        const y = my + ph - t * ph;
        paperVerts.push({ x, y });
      }

      drawingContext.save();
      drawingContext.beginPath();
      drawingContext.moveTo(paperVerts[0].x, paperVerts[0].y);
      for (let i = 1; i < paperVerts.length; i++) {
        drawingContext.lineTo(paperVerts[i].x, paperVerts[i].y);
      }
      drawingContext.closePath();
      drawingContext.clip();
    }

    function restorePaperEdge() {
      drawingContext.restore();
    }

    function drawGrid() {
      const { cols, rows, marginX, marginY } = CONFIG.grid;
      const cellW = (width - marginX * 2) / cols;
      const cellH = (height - marginY * 2) / rows;

      stroke(CONFIG.paper.lineColor[0], CONFIG.paper.lineColor[1], CONFIG.paper.lineColor[2], CONFIG.paper.lineColor[3]);
      strokeWeight(CONFIG.paper.lineWeight);

      for (let i = 0; i <= cols; i++) {
        const x = marginX + i * cellW;
        drawDamagedLine(x, marginY, x, height - marginY, true);
      }
      for (let j = 0; j <= rows; j++) {
        const y = marginY + j * cellH;
        drawDamagedLine(marginX, y, width - marginX, y, false);
      }
      noStroke();
    }

    function drawDamagedLine(x1, y1, x2, y2, isVertical) {
      const steps = 80;
      const warpAmp = CONFIG.gridDamage.warpAmp;
      const baseWeight = CONFIG.paper.lineWeight;
      const warpScale = 0.012;
      const lineId = x1 * 0.37 + y1 * 0.71;

      let prevX = x1, prevY = y1;
      {
        const w = getWetnessAt(x1, y1);
        if (w > 0.1) {
          const ww = w * w;
          const cw = (noise(x1 * warpScale * 2.5 + 500, y1 * warpScale * 2.5 + 500) - 0.5) * 2 * warpAmp * ww;
          if (isVertical) prevX = x1 + cw; else prevY = y1 + cw;
        }
      }

      for (let s = 1; s <= steps; s++) {
        const t = s / steps;
        let sx = lerp(x1, x2, t);
        let sy = lerp(y1, y2, t);

        const w = getWetnessAt(sx, sy);
        let cw = 0;
        if (w > 0.1) {
          // Sharper falloff: square the wetness so only high-wetness areas bend significantly
          const ww = w * w;
          cw = (noise(sx * warpScale * 2.5 + 500, sy * warpScale * 2.5 + 500) - 0.5) * 2 * warpAmp * ww;
        }

        const handNoise = noise(sx * 0.1 + lineId, sy * 0.1);
        const sw = baseWeight * (0.6 + handNoise * 0.8);
        strokeWeight(sw);

        if (isVertical) sx += cw; else sy += cw;

        line(prevX, prevY, sx, sy);
        prevX = sx;
        prevY = sy;
      }
    }

    function drawWaterStains() {
      const { cols, rows, marginX, marginY } = CONFIG.grid;
      const cellW = (width - marginX * 2) / cols;
      const cellH = (height - marginY * 2) / rows;
      const stainColor = [140, 180, 210];

      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          const w = wetGrid[r][c];
          if (w < 0.05) continue;

          const cx = marginX + (c + 0.5) * cellW;
          const cy = marginY + (r + 0.5) * cellH;

          // Deterministic seed per cell
          const seed = r * cols + c;
          randomSeed(seed * 137 + 42);

          const baseR = random(cellW * 0.4, cellW * 0.6) * (0.8 + w * 0.4);
          const ox = (random() - 0.5) * cellW * 0.4;
          const oy = (random() - 0.5) * cellH * 0.4;
          const alpha = w * (50 + random(30));
          const numVerts = 12 + Math.floor(random(5));
          const nOff = seed * 0.73;

          // Subtle hue variation
          const hueShift = random(-1, 1);
          const sr = constrain(stainColor[0] + hueShift * 15, 0, 255);
          const sg = constrain(stainColor[1] - hueShift * 8, 0, 255);
          const sb = constrain(stainColor[2] + (hueShift > 0 ? 10 : -10), 0, 255);

          noStroke();
          fill(sr, sg, sb, alpha);
          beginShape();
          for (let v = 0; v <= numVerts; v++) {
            const angle = (v % numVerts) / numVerts * TWO_PI;
            const rNoise = noise(nOff + cos(angle) * 1.5 + 10, nOff + sin(angle) * 1.5 + 10);
            const rad = baseR * (0.4 + rNoise * 0.8);
            const vx = cx + ox + cos(angle) * rad;
            const vy = cy + oy + sin(angle) * rad;
            curveVertex(vx, vy);
          }
          // Extra control points for smooth closure
          {
            const a0 = 0;
            const rN0 = noise(nOff + cos(a0) * 1.5 + 10, nOff + sin(a0) * 1.5 + 10);
            curveVertex(cx + ox + cos(a0) * baseR * (0.4 + rN0 * 0.8), cy + oy + sin(a0) * baseR * (0.4 + rN0 * 0.8));
            const a1 = TWO_PI / numVerts;
            const rN1 = noise(nOff + cos(a1) * 1.5 + 10, nOff + sin(a1) * 1.5 + 10);
            curveVertex(cx + ox + cos(a1) * baseR * (0.4 + rN1 * 0.8), cy + oy + sin(a1) * baseR * (0.4 + rN1 * 0.8));
          }
          endShape(CLOSE);
        }
      }
      randomSeed(millis());
    }

    function mousePressed() {
      if (mouseX >= 0 && mouseX <= width && mouseY >= 0 && mouseY <= height) {
        // Reset everything
        initWetGrid();
        for (let cd of charData) {
          for (let pt of cd.points) {
            pt.drift = 0;
            pt.x = pt.homeX;
            pt.y = pt.homeY;
          }
        }
      }
    }
  </script>
</Base>
