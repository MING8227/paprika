---
import Base from '../../layouts/Base.astro';
---
<Base title="信 · Letter">
  <article>
    <h1>信 · Letter</h1>
    <div class="article-meta">2026.03.19</div>
    <div class="article-content">
      <p>醒来发现昨天的自己留了一封信，但笔迹不认识。</p>
      <div id="letter-canvas" style="margin: 2.5rem 0; display: flex; justify-content: center;"></div>
      <p style="text-align: center; font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-muted);">
        注视。等字迹慢慢变成别人的。点击加速揭露。
      </p>
      <hr style="margin:3rem 0;opacity:0.2">
      <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted);">
        语义饱和——盯着一个字看久了，它就不像那个字了。不是字变了，是你和它之间的连接断了。
      </p>
    </div>
  </article>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.4/p5.min.js"></script>
  <script is:inline>
    (function() {
      if (!document.querySelector('link[href*="Ma+Shan+Zheng"]')) {
        var link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = 'https://fonts.googleapis.com/css2?family=Ma+Shan+Zheng&family=Liu+Jian+Mao+Cao&display=swap';
        document.head.appendChild(link);
      }

      // --- CONFIG ---
      // Emotion: uncanny familiarity. Analogous cool palette, desaturated.
      // 90% cool blue-grey ground, 10% warm text (familiar layer)
      // Revealed layer: same text, different hand — cooler, larger, rotated
      var CONFIG = {
        W: 520, H: 780,
        // Colors (HSL thinking, stored as RGB for p5)
        bgColor: [235, 233, 228],       // warm off-white paper
        familiarColor: [72, 68, 62],     // warm dark grey — carbon ink, "my" handwriting
        revealedColor: [85, 95, 120],    // cool blue-grey — "someone else's" ink
        // Curves (rain-like, top to bottom)
        numCurves: 8,
        curveGrowSpeed: 2,
        curveXDrift: 0.8,
        curveWeightRange: [12, 20],
        curveSpawnInterval: 90,          // frames between new curves
        maxCurves: 30,
        // Text layout
        fontSize: 19,
        revealFontScale: 1.15,
        charSpacing: 22,
        lineSpacing: 26,
        marginX: 30,
        marginY: 35,
        jitterPos: 1.2,
        jitterRot: 0.02,
        revJitterPos: 3.5,
        revJitterRot: 0.10,
        // Reveal
        revealRadius: 18,               // how close curve must be to reveal
      };

      var TEXT = "昨天的事情我想了很久有些话当时没说出口不是不想说是不知道怎么开口你醒来的时候可能已经不记得了但我还是想写下来其实我不确定你还认不认得这些字每次都是这样我写了很多你读到的只是碎片也许这就够了也许连碎片都太多了那些没说出口的话就永远留在这里了窗外的光已经变了颜色我不知道下一次醒来会不会还是我在两种笔迹之间的缝隙里或许藏着真正想说的话但我已经分不清哪一行是昨天写的哪一行是今天补的字迹越来越不像自己的了也许从来都不是";

      var cells = [];
      var curves = [];
      var framesSinceSpawn = 0;

      // --- Text grid ---
      function buildGrid() {
        cells = [];
        var cols = Math.floor((CONFIG.W - CONFIG.marginX * 2) / CONFIG.charSpacing);
        var rows = Math.floor((CONFIG.H - CONFIG.marginY * 2) / CONFIG.lineSpacing);
        var idx = 0;
        for (var r = 0; r < rows; r++) {
          for (var c = 0; c < cols; c++) {
            var ch = TEXT[idx % TEXT.length];
            idx++;
            cells.push({
              ch: ch,
              x: CONFIG.marginX + c * CONFIG.charSpacing + CONFIG.charSpacing / 2,
              y: CONFIG.marginY + r * CONFIG.lineSpacing + CONFIG.lineSpacing / 2,
              // familiar layer offsets
              ox: (Math.random() - 0.5) * CONFIG.jitterPos * 2,
              oy: (Math.random() - 0.5) * CONFIG.jitterPos * 2,
              oRot: (Math.random() - 0.5) * CONFIG.jitterRot * 2,
              // revealed layer offsets
              rx: (Math.random() - 0.5) * CONFIG.revJitterPos * 2,
              ry: (Math.random() - 0.5) * CONFIG.revJitterPos * 2,
              rRot: (Math.random() - 0.5) * CONFIG.revJitterRot * 2,
              revealed: 0, // 0 to 1
            });
          }
        }
      }

      // --- Curve (like rain streak) ---
      function spawnCurve(startX) {
        return {
          points: [{ x: startX, y: -10 }],
          speed: CONFIG.curveGrowSpeed + Math.random() * 1.5,
          weight: CONFIG.curveWeightRange[0] + Math.random() * (CONFIG.curveWeightRange[1] - CONFIG.curveWeightRange[0]),
          noiseOff: Math.random() * 1000,
          done: false,
        };
      }

      function growCurve(curve, p) {
        if (curve.done) return;
        var last = curve.points[curve.points.length - 1];
        // drift x with perlin noise, always move down
        var drift = (p.noise(last.y * 0.005, curve.noiseOff) - 0.5) * CONFIG.curveXDrift * 2;
        var nx = last.x + drift;
        var ny = last.y + curve.speed;
        // soft bounce x
        if (nx < 10) nx = 10;
        if (nx > CONFIG.W - 10) nx = CONFIG.W - 10;
        if (ny > CONFIG.H + 20) { curve.done = true; return; }
        curve.points.push({ x: nx, y: ny });
      }

      // --- p5 sketch ---
      new p5(function(p) {
        p.setup = function() {
          var canvas = p.createCanvas(CONFIG.W, CONFIG.H);
          canvas.parent('letter-canvas');
          p.pixelDensity(1);
          p.textAlign(p.CENTER, p.CENTER);
          buildGrid();
          // first curve
          curves.push(spawnCurve(CONFIG.W * 0.3 + Math.random() * CONFIG.W * 0.4));
        };

        p.draw = function() {
          // Paper background with subtle noise
          p.background(CONFIG.bgColor[0], CONFIG.bgColor[1], CONFIG.bgColor[2]);
          p.loadPixels();
          for (var i = 0; i < p.pixels.length; i += 12) {
            var n = (Math.random() - 0.5) * 6;
            p.pixels[i] += n; p.pixels[i+1] += n; p.pixels[i+2] += n;
          }
          p.updatePixels();

          // Spawn new curves periodically
          framesSinceSpawn++;
          if (framesSinceSpawn >= CONFIG.curveSpawnInterval && curves.length < CONFIG.maxCurves) {
            curves.push(spawnCurve(CONFIG.marginX + Math.random() * (CONFIG.W - CONFIG.marginX * 2)));
            framesSinceSpawn = 0;
          }

          // Grow curves
          for (var ci = 0; ci < curves.length; ci++) {
            for (var s = 0; s < 3; s++) growCurve(curves[ci], p);
          }

          // Update reveal: any cell near a curve point gets revealed
          var rr = CONFIG.revealRadius;
          var rrSq = rr * rr;
          for (var ci2 = 0; ci2 < cells.length; ci2++) {
            var cell = cells[ci2];
            if (cell.revealed >= 1) continue;
            for (var cj = 0; cj < curves.length; cj++) {
              var pts = curves[cj].points;
              // only check recent points for performance
              var start = Math.max(0, pts.length - 30);
              for (var k = start; k < pts.length; k++) {
                var dx = cell.x - pts[k].x;
                var dy = cell.y - pts[k].y;
                if (dx * dx + dy * dy < rrSq) {
                  cell.revealed = Math.min(1, cell.revealed + 0.08);
                  break;
                }
              }
              if (cell.revealed >= 1) break;
            }
          }

          // Draw curves (very faint, like water trails)
          p.noFill();
          for (var ci3 = 0; ci3 < curves.length; ci3++) {
            var pts2 = curves[ci3].points;
            if (pts2.length < 2) continue;
            p.stroke(CONFIG.bgColor[0] - 8, CONFIG.bgColor[1] - 8, CONFIG.bgColor[2] - 6, 35);
            p.strokeWeight(curves[ci3].weight);
            p.beginShape();
            for (var k2 = 0; k2 < pts2.length; k2 += 2) {
              p.curveVertex(pts2[k2].x, pts2[k2].y);
            }
            p.endShape();
          }
          p.noStroke();

          // Draw text
          for (var ci4 = 0; ci4 < cells.length; ci4++) {
            var c = cells[ci4];
            var rev = c.revealed;

            // Familiar layer (fades as revealed)
            if (rev < 1) {
              var famAlpha = Math.round((1 - rev) * 220);
              p.fill(CONFIG.familiarColor[0], CONFIG.familiarColor[1], CONFIG.familiarColor[2], famAlpha);
              p.push();
              p.translate(c.x + c.ox, c.y + c.oy);
              p.rotate(c.oRot);
              p.textFont('Ma Shan Zheng');
              p.textSize(CONFIG.fontSize);
              p.text(c.ch, 0, 0);
              p.pop();
            }

            // Revealed layer (appears as revealed)
            if (rev > 0) {
              var revAlpha = Math.round(rev * 240);
              p.fill(CONFIG.revealedColor[0], CONFIG.revealedColor[1], CONFIG.revealedColor[2], revAlpha);
              p.push();
              p.translate(c.x + c.rx, c.y + c.ry);
              p.rotate(c.rRot);
              p.textFont('Liu Jian Mao Cao');
              p.textSize(CONFIG.fontSize * CONFIG.revealFontScale);
              p.text(c.ch, 0, 0);
              p.pop();
            }
          }
        };

        // Click to add revelation curve at that position
        p.mousePressed = function() {
          if (p.mouseX > 0 && p.mouseX < CONFIG.W && p.mouseY > 0 && p.mouseY < CONFIG.H) {
            curves.push(spawnCurve(p.mouseX));
          }
        };
      });
    })();
  </script>
</Base>
