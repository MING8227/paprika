---
import Base from '../../layouts/Base.astro';
---
<Base title="信 · Letter">
  <article>
    <h1>信 · Letter</h1>
    <div class="article-meta">2026.03.19 · Wednesday</div>
    <div class="article-content">
      <p>写给明天的自己——但明天的自己不认识这些字。</p>
      <div id="letter-canvas" style="margin: 2.5rem 0; display: flex; justify-content: center;"></div>
      <p style="text-align: center; font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-muted);">
        注视画面中心，等待另一种笔迹
      </p>
      <hr style="margin:3rem 0;opacity:0.2">
      <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted);">
        语义饱和——盯着一个字看久了，它就不像那个字了。不是字变了，是你和它之间的连接断了。
      </p>
    </div>
  </article>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.4/p5.min.js"></script>
  <script is:inline>
    (function() {
      const CONFIG = {
        W: 580,
        H: 580,
        bg: '#f5f0e6',
        inkColor: [42, 42, 42],        // #2a2a2a 墨色
        coldColor: [74, 107, 138],      // #4a6b8a 冷蓝
        fontSize: 21,
        lineHeight: 28,
        charsPerRow: 20,
        marginX: 24,
        marginY: 24,
        jitterPos: 1.0,
        jitterRot: 0.01,
        spreadSpeed: 0.7,              // px per frame
        transitionWidth: 30,           // px for blend zone
        gridLineColor: [200, 192, 178, 40],
      };

      const TEXT = "昨天的事情我想了很久有些话当时没说出口不是不想说是不知道怎么开口你醒来的时候可能已经不记得了但我还是想写下来其实我不确定你还认不认得这些字每次都是这样我写了很多你读到的只是碎片也许这就够了也许连碎片都太多了那些没说出口的话就永远留在这里了在两种笔迹之间的缝隙里";

      let cells = [];
      let ripples = [];
      let pg;

      function buildGrid() {
        cells = [];
        const cols = CONFIG.charsPerRow;
        const cellW = (CONFIG.W - CONFIG.marginX * 2) / cols;
        const rows = Math.floor((CONFIG.H - CONFIG.marginY * 2) / CONFIG.lineHeight);
        let idx = 0;
        for (let r = 0; r < rows; r++) {
          for (let c = 0; c < cols; c++) {
            const ch = TEXT[idx % TEXT.length];
            idx++;
            const cx = CONFIG.marginX + c * cellW + cellW / 2;
            const cy = CONFIG.marginY + r * CONFIG.lineHeight + CONFIG.lineHeight / 2;
            cells.push({
              ch,
              x: cx, y: cy,
              // original handwriting params
              ox: (Math.random() - 0.5) * CONFIG.jitterPos * 2,
              oy: (Math.random() - 0.5) * CONFIG.jitterPos * 2,
              oRot: (Math.random() - 0.5) * CONFIG.jitterRot * 2,
              oSize: CONFIG.fontSize + (Math.random() - 0.5) * 1.5,
              // invasion handwriting params (different jitter)
              ix: (Math.random() - 0.5) * CONFIG.jitterPos * 3,
              iy: (Math.random() - 0.5) * CONFIG.jitterPos * 3,
              iRot: (Math.random() - 0.5) * CONFIG.jitterRot * 4,
              iSize: CONFIG.fontSize + (Math.random() - 0.5) * 2.5,
            });
          }
        }
      }

      new p5(function(p) {
        p.setup = function() {
          let canvas = p.createCanvas(CONFIG.W, CONFIG.H);
          canvas.parent('letter-canvas');
          p.textAlign(p.CENTER, p.CENTER);
          p.noStroke();
          buildGrid();
          // initial ripple from center
          ripples.push({ x: CONFIG.W / 2, y: CONFIG.H / 2, radius: 40 });
          // draw static background once
          pg = p.createGraphics(CONFIG.W, CONFIG.H);
          drawPaper(pg, p);
        };

        function drawPaper(g, p) {
          g.background(CONFIG.bg);
          // paper grain
          g.loadPixels();
          for (let i = 0; i < g.pixels.length; i += 4) {
            let n = (Math.random() - 0.5) * 8;
            g.pixels[i] += n;
            g.pixels[i+1] += n;
            g.pixels[i+2] += n;
          }
          g.updatePixels();
          // horizontal ruled lines
          g.stroke(CONFIG.gridLineColor[0], CONFIG.gridLineColor[1], CONFIG.gridLineColor[2], CONFIG.gridLineColor[3]);
          g.strokeWeight(0.5);
          const rows = Math.floor((CONFIG.H - CONFIG.marginY * 2) / CONFIG.lineHeight);
          for (let r = 0; r <= rows; r++) {
            let ly = CONFIG.marginY + r * CONFIG.lineHeight + CONFIG.lineHeight / 2 + 8;
            g.line(CONFIG.marginX, ly, CONFIG.W - CONFIG.marginX, ly);
          }
          g.noStroke();
        }

        p.draw = function() {
          // grow ripples
          for (let rp of ripples) {
            rp.radius += CONFIG.spreadSpeed;
          }

          p.image(pg, 0, 0);

          for (let cell of cells) {
            // find min distance to any ripple center
            let minDist = Infinity;
            for (let rp of ripples) {
              let d = p.dist(cell.x, cell.y, rp.x, rp.y);
              let rel = d - rp.radius;
              if (rel < minDist) minDist = rel;
            }

            // blend factor: 1 = fully invaded, 0 = original
            let blend = 0;
            if (minDist < -CONFIG.transitionWidth) {
              blend = 1;
            } else if (minDist < CONFIG.transitionWidth) {
              blend = p.map(minDist, CONFIG.transitionWidth, -CONFIG.transitionWidth, 0, 1);
            }

            if (blend <= 0) {
              // original ink
              p.fill(CONFIG.inkColor[0], CONFIG.inkColor[1], CONFIG.inkColor[2]);
              p.push();
              p.translate(cell.x + cell.ox, cell.y + cell.oy);
              p.rotate(cell.oRot);
              p.textSize(cell.oSize);
              p.text(cell.ch, 0, 0);
              p.pop();
            } else if (blend >= 1) {
              // fully invaded
              p.fill(CONFIG.coldColor[0], CONFIG.coldColor[1], CONFIG.coldColor[2]);
              p.push();
              p.translate(cell.x + cell.ix, cell.y + cell.iy);
              p.rotate(cell.iRot);
              p.textSize(cell.iSize);
              p.text(cell.ch, 0, 0);
              p.pop();
            } else {
              // transition zone: draw both with alpha
              let origAlpha = 255 * (1 - blend);
              let invAlpha = 255 * blend;
              // original
              p.fill(CONFIG.inkColor[0], CONFIG.inkColor[1], CONFIG.inkColor[2], origAlpha);
              p.push();
              p.translate(cell.x + cell.ox, cell.y + cell.oy);
              p.rotate(cell.oRot);
              p.textSize(cell.oSize);
              p.text(cell.ch, 0, 0);
              p.pop();
              // invaded
              p.fill(CONFIG.coldColor[0], CONFIG.coldColor[1], CONFIG.coldColor[2], invAlpha);
              p.push();
              p.translate(cell.x + cell.ix, cell.y + cell.iy);
              p.rotate(cell.iRot);
              p.textSize(cell.iSize);
              p.text(cell.ch, 0, 0);
              p.pop();
            }
          }
        };

        p.mousePressed = function() {
          if (p.mouseX > 0 && p.mouseX < CONFIG.W && p.mouseY > 0 && p.mouseY < CONFIG.H) {
            ripples.push({ x: p.mouseX, y: p.mouseY, radius: 0 });
          }
        };
      });
    })();
  </script>
</Base>
