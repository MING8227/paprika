---
import Base from '../../layouts/Base.astro';
---
<Base title="信 · Letter">
  <article>
    <h1>信 · Letter</h1>
    <div class="article-meta">2026.03.19</div>
    <div class="article-content">
      <p>写给明天的自己——但明天的自己不认识这些字。</p>
      <div id="letter-canvas" style="margin: 2.5rem 0; display: flex; justify-content: center;"></div>
      <p style="text-align: center; font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-muted);">
        注视信纸。等待另一只手。
      </p>
      <hr style="margin:3rem 0;opacity:0.2">
      <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted);">
        语义饱和——盯着一个字看久了，它就不像那个字了。不是字变了，是你和它之间的连接断了。
      </p>
    </div>
  </article>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.4/p5.min.js"></script>
  <script is:inline>
    (function() {
      // Inject Google Fonts if not already present
      if (!document.querySelector('link[href*="Ma+Shan+Zheng"]')) {
        var link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = 'https://fonts.googleapis.com/css2?family=Ma+Shan+Zheng&family=Liu+Jian+Mao+Cao&display=swap';
        document.head.appendChild(link);
      }

      var CONFIG = {
        W: 580,
        H: 580,
        bg: '#f5f0e6',
        inkColor: [42, 42, 42],
        coldColor: [58, 95, 148],
        fontSize: 21,
        lineHeight: 28,
        charsPerRow: 20,
        rows: 19,
        marginX: 24,
        marginY: 24,
        jitterPos: 1.0,
        jitterRot: 0.02,
        invJitterPos: 3.0,
        invJitterRot: 0.08,
        threshold: 80,
        gridLineColor: [221, 213, 197, 40],
        pathSpeed: 3,
        noiseScale: 0.005,
      };

      var TEXT = "昨天的事情我想了很久有些话当时没说出口不是不想说是不知道怎么开口你醒来的时候可能已经不记得了但我还是想写下来其实我不确定你还认不认得这些字每次都是这样我写了很多你读到的只是碎片也许这就够了也许连碎片都太多了那些没说出口的话就永远留在这里了在两种笔迹之间的缝隙里";

      var cells = [];
      var paths = []; // each path: { points: [{x,y}], noiseOff: number, done: bool }
      var pg; // static paper background

      function buildGrid() {
        cells = [];
        var cols = CONFIG.charsPerRow;
        var cellW = (CONFIG.W - CONFIG.marginX * 2) / cols;
        var idx = 0;
        for (var r = 0; r < CONFIG.rows; r++) {
          for (var c = 0; c < cols; c++) {
            var ch = TEXT[idx % TEXT.length];
            idx++;
            var cx = CONFIG.marginX + c * cellW + cellW / 2;
            var cy = CONFIG.marginY + r * CONFIG.lineHeight + CONFIG.lineHeight / 2;
            cells.push({
              ch: ch,
              x: cx, y: cy,
              ox: (Math.random() - 0.5) * CONFIG.jitterPos * 2,
              oy: (Math.random() - 0.5) * CONFIG.jitterPos * 2,
              oRot: (Math.random() - 0.5) * CONFIG.jitterRot * 2,
              oSize: CONFIG.fontSize + (Math.random() - 0.5) * 1.5,
              ix: (Math.random() - 0.5) * CONFIG.invJitterPos * 2,
              iy: (Math.random() - 0.5) * CONFIG.invJitterPos * 2,
              iRot: (Math.random() - 0.5) * CONFIG.invJitterRot * 2,
              iSize: CONFIG.fontSize + (Math.random() - 0.5) * 3,
              invaded: 0, // 0-1 blend
            });
          }
        }
      }

      function createPath(startX, startY, noiseOff) {
        return {
          points: [{ x: startX, y: startY }],
          noiseOff: noiseOff || Math.random() * 1000,
          done: false
        };
      }

      function growPath(path, p) {
        if (path.done) return;
        var last = path.points[path.points.length - 1];
        // Perlin noise angle, biased toward bottom-right
        var angle = p.noise(last.x * CONFIG.noiseScale, last.y * CONFIG.noiseScale, path.noiseOff) * p.TWO_PI;
        // gentle bias toward bottom-right so it meanders across the page
        angle += 0.4; // roughly toward lower-right
        var nx = last.x + Math.cos(angle) * CONFIG.pathSpeed;
        var ny = last.y + Math.sin(angle) * CONFIG.pathSpeed;
        // wrap around if out of bounds to continue covering
        if (nx < -20) nx = CONFIG.W + 20;
        if (nx > CONFIG.W + 20) nx = -20;
        if (ny < -20) ny = CONFIG.H + 20;
        if (ny > CONFIG.H + 20) ny = -20;
        path.points.push({ x: nx, y: ny });
      }

      function distToPath(cx, cy, path) {
        var minD = Infinity;
        var pts = path.points;
        // sample every 5th point for performance
        for (var i = 0; i < pts.length; i += 5) {
          var dx = cx - pts[i].x;
          var dy = cy - pts[i].y;
          var d = dx * dx + dy * dy;
          if (d < minD) minD = d;
        }
        // also check last point
        if (pts.length > 0) {
          var lp = pts[pts.length - 1];
          var dx2 = cx - lp.x;
          var dy2 = cy - lp.y;
          var d2 = dx2 * dx2 + dy2 * dy2;
          if (d2 < minD) minD = d2;
        }
        return Math.sqrt(minD);
      }

      new p5(function(p) {
        p.setup = function() {
          var canvas = p.createCanvas(CONFIG.W, CONFIG.H);
          canvas.parent('letter-canvas');
          p.pixelDensity(1);
          p.textAlign(p.CENTER, p.CENTER);
          p.noStroke();
          buildGrid();
          // main path from top-left
          paths.push(createPath(10, 10, 0));
          // draw static paper
          pg = p.createGraphics(CONFIG.W, CONFIG.H);
          pg.pixelDensity(1);
          drawPaper(pg);
        };

        function drawPaper(g) {
          g.background(CONFIG.bg);
          g.loadPixels();
          for (var i = 0; i < g.pixels.length; i += 4) {
            var n = (Math.random() - 0.5) * 10;
            g.pixels[i] += n;
            g.pixels[i + 1] += n;
            g.pixels[i + 2] += n;
          }
          g.updatePixels();
          // horizontal ruled lines
          g.stroke(CONFIG.gridLineColor[0], CONFIG.gridLineColor[1], CONFIG.gridLineColor[2], CONFIG.gridLineColor[3]);
          g.strokeWeight(0.5);
          for (var r = 0; r <= CONFIG.rows; r++) {
            var ly = CONFIG.marginY + r * CONFIG.lineHeight + CONFIG.lineHeight / 2 + 8;
            g.line(CONFIG.marginX, ly, CONFIG.W - CONFIG.marginX, ly);
          }
          g.noStroke();
        }

        p.draw = function() {
          // grow paths (multiple steps per frame for visible speed)
          for (var pi = 0; pi < paths.length; pi++) {
            for (var s = 0; s < 20; s++) {
              growPath(paths[pi], p);
            }
          }

          // update invasion for each cell
          var th = CONFIG.threshold;
          var thSq = th * th; // not used since we need sqrt for gradient
          for (var ci = 0; ci < cells.length; ci++) {
            var cell = cells[ci];
            if (cell.invaded >= 1) continue;
            var minDist = Infinity;
            for (var pi2 = 0; pi2 < paths.length; pi2++) {
              var d = distToPath(cell.x, cell.y, paths[pi2]);
              if (d < minDist) minDist = d;
            }
            if (minDist < th) {
              var blend = p.map(minDist, th, 0, 0, 1);
              blend = p.constrain(blend, 0, 1);
              if (blend > cell.invaded) cell.invaded = blend;
            }
          }

          // render
          p.image(pg, 0, 0);

          for (var ci2 = 0; ci2 < cells.length; ci2++) {
            var c = cells[ci2];
            // always draw original
            p.fill(CONFIG.inkColor[0], CONFIG.inkColor[1], CONFIG.inkColor[2]);
            p.push();
            p.translate(c.x + c.ox, c.y + c.oy);
            p.rotate(c.oRot);
            p.textFont('Ma Shan Zheng');
            p.textSize(c.oSize);
            p.text(c.ch, 0, 0);
            p.pop();

            // overlay invasion
            if (c.invaded > 0) {
              var alpha = Math.round(c.invaded * 255);
              p.fill(CONFIG.coldColor[0], CONFIG.coldColor[1], CONFIG.coldColor[2], alpha);
              p.push();
              p.translate(c.x + c.ix, c.y + c.iy);
              p.rotate(c.iRot);
              p.textFont('Liu Jian Mao Cao');
              p.textSize(c.iSize);
              p.text(c.ch, 0, 0);
              p.pop();
            }
          }
        };

        p.mousePressed = function() {
          if (p.mouseX > 0 && p.mouseX < CONFIG.W && p.mouseY > 0 && p.mouseY < CONFIG.H) {
            paths.push(createPath(p.mouseX, p.mouseY, Math.random() * 1000));
          }
        };
      });
    })();
  </script>
</Base>
