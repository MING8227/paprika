---
import Base from '../../layouts/Base.astro';
---

<Base title="信 · Letter">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.0/p5.min.js" is:inline></script>
  <script is:inline>
    const CONFIG = {
      canvas: { width: 580, height: 780 },
      grid: { cols: 14, rows: 20, marginX: 40, marginY: 40 },
      text: {
        content: "醒来发现昨天的自己留了一封信但笔迹不认识你试着读每个字都认得但连在一起又觉得陌生信的最后写着别担心但你不知道是谁在安慰谁",
        sampleSize: 72,
        displaySize: 18,
        color: [74, 69, 64],
        pointDensity: 0.18
      },
      paper: {
        bg: [250, 250, 252],
        lineColor: [120, 160, 155, 180],
        lineWeight: 0.8
      },
      damage: {
        driftMax: 12,
        driftSpeed: 0.008,
        fadeAlpha: 80,
        rustColor: [180, 75, 55],
        rustAlpha: 0.2,
        rustCount: 0
      },
      curve: {
        growSpeed: 1.5,
        xDriftScale: 0.004,
        weight: 60,
        spawnInterval: 350,
        maxCurves: 4,
        startYRange: [-30, 0]
      },
      // A: color inheritance along curve trail
      colorInherit: {
        baseColor: [74, 69, 64],
        warmColor: [180, 75, 55],
        // drift threshold where color starts shifting
        driftStart: 0.05
      },
      // B: grid damage
      gridDamage: {
        radius: 50,
        breakGap: 8,
        offsetMax: 5
      },
      // C: visual weight layers
      visualWeight: {
        pristine:  { size: 0.4, alpha: 180 },
        eroding:   { sizeMin: 0.4, sizeMax: 0.6, alphaMin: 60, alphaMax: 180, driftRange: [0.01, 0.5] },
        eroded:    { sizeMin: 0.6, sizeMax: 1.0, alphaMin: 20,  alphaMax: 60, driftThreshold: 0.5 }
      }
    };

    let sanShengFont;
    let charData = [];
    let curves = [];
    let curveHistory = []; // stored trail points for grid damage + color
    let lastSpawnFrame = -150;

    function preload() {
      sanShengFont = loadFont('/paprika/fonts/SanSheng-subset.ttf');
    }

    function setup() {
      pixelDensity(1);
      const canvas = createCanvas(CONFIG.canvas.width, CONFIG.canvas.height);
      canvas.parent(document.querySelector('main') || document.body);

      buildCharPoints();
      noStroke();
    }

    function buildCharPoints() {
      const { cols, rows, marginX, marginY } = CONFIG.grid;
      const cellW = (width - marginX * 2) / cols;
      const cellH = (height - marginY * 2) / rows;
      const content = CONFIG.text.content;
      const scale = CONFIG.text.displaySize / CONFIG.text.sampleSize;

      let idx = 0;
      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          const ch = content[idx % content.length];
          idx++;

          const cx = marginX + (c + 0.5) * cellW;
          const cy = marginY + (r + 0.5) * cellH;

          let rawPoints;
          try {
            rawPoints = sanShengFont.textToPoints(ch, 0, 0, CONFIG.text.sampleSize, {
              sampleFactor: CONFIG.text.pointDensity
            });
          } catch(e) {
            rawPoints = [];
          }

          if (rawPoints.length === 0) continue;

          let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
          for (let p of rawPoints) {
            if (p.x < minX) minX = p.x;
            if (p.x > maxX) maxX = p.x;
            if (p.y < minY) minY = p.y;
            if (p.y > maxY) maxY = p.y;
          }
          const offX = (minX + maxX) / 2;
          const offY = (minY + maxY) / 2;

          const points = rawPoints.map(p => ({
            homeX: cx + (p.x - offX) * scale,
            homeY: cy + (p.y - offY) * scale,
            x: cx + (p.x - offX) * scale,
            y: cy + (p.y - offY) * scale,
            drift: 0,
            noiseOff: random(1000),
            phase: random(TWO_PI)
          }));

          charData.push({ cx, cy, points, char: ch, damaged: false, wetness: 0 });
        }
      }
    }

    function spawnCurve(sx, sy) {
      if (curves.length >= CONFIG.curve.maxCurves) return;
      curves.push({
        x: sx !== undefined ? sx : random(CONFIG.grid.marginX + 30, width - CONFIG.grid.marginX - 30),
        y: sy !== undefined ? sy : random(CONFIG.curve.startYRange[0], CONFIG.curve.startYRange[1]),
        noiseOff: random(1000),
        active: true
      });
    }

    // Check if a point is near any curve trail
    function curveInfluenceAt(px, py, radius) {
      let maxInf = 0;
      for (let trail of curveHistory) {
        const dx = px - trail.x;
        const dy = py - trail.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < radius) {
          const inf = 1 - dist / radius;
          if (inf > maxInf) maxInf = inf;
        }
      }
      return maxInf;
    }

    function draw() {
      background(CONFIG.paper.bg[0], CONFIG.paper.bg[1], CONFIG.paper.bg[2]);

      drawPaperEdge(); // clip to irregular paper outline
      drawWaterStains();
      drawGrid();

      // spawn curves — progressive slowdown: first few fast, then slower
      const curveCount = curves.length;
      const interval = curveCount < 3 ? CONFIG.curve.spawnInterval : CONFIG.curve.spawnInterval + curveCount * 120;
      if (frameCount - lastSpawnFrame >= interval) {
        spawnCurve();
        lastSpawnFrame = frameCount;
      }

      // grow curves & affect nearby chars
      const halfW = CONFIG.curve.weight / 2;
      for (let cv of curves) {
        if (!cv.active) continue;
        cv.y += CONFIG.curve.growSpeed;
        cv.x += (noise(cv.noiseOff) - 0.5) * 2 * 8;
        cv.noiseOff += CONFIG.curve.xDriftScale * 60;

        if (cv.y > height + 20) {
          cv.active = false;
          continue;
        }

        // record trail for grid damage + color inheritance
        curveHistory.push({ x: cv.x, y: cv.y });

        // affect chars near this curve segment — increase wetness, not drift directly
        for (let cd of charData) {
          const dy = cv.y - cd.cy;
          const dx = cv.x - cd.cx;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < halfW) {
            const influence = 1 - dist / halfW;
            cd.wetness = min(1, cd.wetness + influence * 0.08);
          }
        }
      }

      // cap trail history to avoid memory bloat
      if (curveHistory.length > 3000) {
        curveHistory = curveHistory.slice(-2000);
      }

      // chars drift only where wet (water stain coverage)
      for (let cd of charData) {
        if (cd.wetness > 0.02) {
          for (let pt of cd.points) {
            pt.drift = min(1, pt.drift + cd.wetness * 0.003);
          }
        }
      }

      // draw all chars: pristine = text(), eroding/eroded = stroke lines
      const base = CONFIG.colorInherit.baseColor;
      const warm = CONFIG.colorInherit.warmColor;
      const dm = CONFIG.damage;
      const vw = CONFIG.visualWeight;

      for (let cd of charData) {
        // compute max drift for this char
        let maxDrift = 0;
        for (let pt of cd.points) {
          if (pt.drift > maxDrift) maxDrift = pt.drift;
        }

        if (maxDrift <= 0.01) {
          // PRISTINE: draw as solid text, but apply grid-like warp if near curve
          const inf = curveInfluenceAt(cd.cx, cd.cy, CONFIG.gridDamage.radius);
          let drawX = cd.cx;
          let drawY = cd.cy;
          if (inf > 0.05) {
            const warpX = (noise(cd.cx * 0.03, cd.cy * 0.03) - 0.5) * 2 * inf * 8;
            const warpY = (noise(cd.cx * 0.03 + 200, cd.cy * 0.03 + 200) - 0.5) * 2 * inf * 8;
            drawX += warpX;
            drawY += warpY;
          }
          noStroke();
          fill(base[0], base[1], base[2], vw.pristine.alpha);
          textFont(sanShengFont);
          textSize(CONFIG.text.displaySize);
          textAlign(CENTER, CENTER);
          text(cd.char, drawX, drawY);
        } else {
          // ERODING/ERODED: update positions and draw as lines
          for (let pt of cd.points) {
            if (pt.drift > 0.01) {
              const nx = noise(pt.noiseOff, frameCount * dm.driftSpeed);
              const ny = noise(pt.noiseOff + 500, frameCount * dm.driftSpeed);
              pt.x = pt.homeX + (nx - 0.5) * 2 * dm.driftMax * pt.drift;
              pt.y = pt.homeY + (ny - 0.5) * 2 * dm.driftMax * pt.drift;
            }
          }

          noFill();
          const pts = cd.points;
          for (let i = 0; i < pts.length - 1; i++) {
            const pt = pts[i];
            const pt2 = pts[i + 1];
            const d = max(pt.drift, pt2.drift);

            const gap = dist(pt.x, pt.y, pt2.x, pt2.y);
            if (gap > 8) continue;

            const colorT = constrain(map(d, CONFIG.colorInherit.driftStart, 1, 0, 1), 0, 1);
            const cr = lerp(base[0], warm[0], colorT);
            const cg = lerp(base[1], warm[1], colorT);
            const cb = lerp(base[2], warm[2], colorT);

            if (d > vw.eroded.driftThreshold) {
              const t = constrain(map(d, 0.5, 1, 0, 1), 0, 1);
              const alpha = lerp(vw.eroded.alphaMax, vw.eroded.alphaMin, t);
              const sw = lerp(vw.eroded.sizeMin, vw.eroded.sizeMax, t);
              if ((pt.noiseOff * 7) % 1 < 0.7) {
                stroke(cr, cg, cb, alpha);
                strokeWeight(sw);
                line(pt.x, pt.y, pt2.x, pt2.y);
              }
            } else if (d > 0.01) {
              const t = constrain(map(d, vw.eroding.driftRange[0], vw.eroding.driftRange[1], 0, 1), 0, 1);
              const alpha = lerp(vw.eroding.alphaMax, vw.eroding.alphaMin, t);
              const sw = lerp(vw.eroding.sizeMin, vw.eroding.sizeMax, t);
              stroke(cr, cg, cb, alpha);
              strokeWeight(sw);
              line(pt.x, pt.y, pt2.x, pt2.y);
            } else {
              stroke(base[0], base[1], base[2], vw.pristine.alpha);
              strokeWeight(vw.pristine.size);
              line(pt.x, pt.y, pt2.x, pt2.y);
            }
          }
        }
      }
      noStroke();
      restorePaperEdge(); // remove clip
    }

    function drawPaperEdge() {
      // Draw irregular paper outline — noise-warped rectangle
      // Everything outside is masked with background color
      const bg = CONFIG.paper.bg;
      const mx = CONFIG.grid.marginX;
      const my = CONFIG.grid.marginY;
      const pw = width - mx * 2;
      const ph = height - my * 2;
      const amp = 7; // edge irregularity amplitude
      const noiseScale = 0.015;
      const edgeSteps = 120; // vertices per edge

      // Build the irregular paper contour
      let paperVerts = [];

      // Top edge (left to right)
      for (let i = 0; i <= edgeSteps; i++) {
        const t = i / edgeSteps;
        const x = mx + t * pw;
        const y = my + (noise(x * noiseScale, 0) - 0.5) * 2 * amp;
        paperVerts.push({ x, y });
      }
      // Right edge (top to bottom)
      for (let i = 1; i <= edgeSteps; i++) {
        const t = i / edgeSteps;
        const x = mx + pw + (noise(1000, t * ph * noiseScale) - 0.5) * 2 * amp;
        const y = my + t * ph;
        paperVerts.push({ x, y });
      }
      // Bottom edge (right to left)
      for (let i = 1; i <= edgeSteps; i++) {
        const t = i / edgeSteps;
        const x = mx + pw - t * pw;
        const y = my + ph + (noise(x * noiseScale, 2000) - 0.5) * 2 * amp;
        paperVerts.push({ x, y });
      }
      // Left edge (bottom to top)
      for (let i = 1; i < edgeSteps; i++) {
        const t = i / edgeSteps;
        const x = mx + (noise(3000, t * ph * noiseScale) - 0.5) * 2 * amp;
        const y = my + ph - t * ph;
        paperVerts.push({ x, y });
      }

      // Draw mask: fill the outside with background color
      // Use 4 quads covering each side outside the paper
      const pad = 50; // extra padding beyond canvas
      noStroke();
      fill(bg[0], bg[1], bg[2]);

      // We use a trick: draw background over whole canvas, then draw paper shape
      // Actually, easier: draw the paper contour as a filled shape first (before grid),
      // then draw background rectangles around it. But that clips grid too.
      // Best approach: use erase/noErase or drawingContext.clip

      // Use canvas clip to restrict all subsequent drawing to paper shape
      drawingContext.save();
      drawingContext.beginPath();
      drawingContext.moveTo(paperVerts[0].x, paperVerts[0].y);
      for (let i = 1; i < paperVerts.length; i++) {
        drawingContext.lineTo(paperVerts[i].x, paperVerts[i].y);
      }
      drawingContext.closePath();
      drawingContext.clip();
    }

    function restorePaperEdge() {
      drawingContext.restore();
    }

    function drawGrid() {
      const { cols, rows, marginX, marginY } = CONFIG.grid;
      const cellW = (width - marginX * 2) / cols;
      const cellH = (height - marginY * 2) / rows;
      const gd = CONFIG.gridDamage;

      stroke(CONFIG.paper.lineColor[0], CONFIG.paper.lineColor[1], CONFIG.paper.lineColor[2], CONFIG.paper.lineColor[3]);
      strokeWeight(CONFIG.paper.lineWeight);

      // vertical lines with global warp + curve damage
      for (let i = 0; i <= cols; i++) {
        const x = marginX + i * cellW;
        drawDamagedLine(x, marginY, x, height - marginY, true, gd);
      }
      // horizontal lines with global warp + curve damage
      for (let j = 0; j <= rows; j++) {
        const y = marginY + j * cellH;
        drawDamagedLine(marginX, y, width - marginX, y, false, gd);
      }
      noStroke();
    }

    function drawDamagedLine(x1, y1, x2, y2, isVertical, gd) {
      // Global perlin warp on all lines (3-5px base) + extra near curves (15-20px)
      const steps = 80;
      const baseWarpAmp = 4;    // global warp amplitude
      const curveWarpAmp = 18;  // extra warp near curves
      const baseWeight = CONFIG.paper.lineWeight;
      const warpScaleX = 0.012;
      const warpScaleY = 0.012;
      // Use line identity as noise seed offset
      const lineId = x1 * 0.37 + y1 * 0.71;
      let prevX = x1, prevY = y1;

      // Apply curve warp to starting point (no global warp — grid only bends near water)
      {
        const inf = curveInfluenceAt(x1, y1, gd.radius);
        const cw = inf > 0.05 ? curveWarp(x1, y1, isVertical, curveWarpAmp * inf, warpScaleX) : 0;
        if (isVertical) { prevX = x1 + cw; } else { prevY = y1 + cw; }
      }

      for (let s = 1; s <= steps; s++) {
        const t = s / steps;
        let sx = lerp(x1, x2, t);
        let sy = lerp(y1, y2, t);

        // No global warp — grid only bends near curve trails (water drops)
        // Curve proximity: extra warp near curve trails
        const inf = curveInfluenceAt(sx, sy, gd.radius);
        const cw = inf > 0.05 ? curveWarp(sx, sy, isVertical, curveWarpAmp * inf, warpScaleX) : 0;

        // Hand-drawn weight variation
        const handNoise = noise(sx * 0.1 + lineId, sy * 0.1);
        const sw = baseWeight * (0.6 + handNoise * 0.8);
        strokeWeight(sw);

        if (isVertical) {
          sx += cw;
        } else {
          sy += cw;
        }

        line(prevX, prevY, sx, sy);
        prevX = sx;
        prevY = sy;
      }
    }

    function globalWarp(x, y, isVertical, amp, scaleX, scaleY, lineId) {
      // Smooth perlin-based perpendicular displacement for every line
      const n = (noise(x * scaleX + lineId * 0.1, y * scaleY + lineId * 0.2) - 0.5) * 2;
      return n * amp;
    }

    function curveWarp(x, y, isVertical, amp, scale) {
      // Extra warp displacement near curves — different noise octave
      const n = (noise(x * scale * 2.5 + 500, y * scale * 2.5 + 500) - 0.5) * 2;
      return n * amp;
    }

    function drawWaterStains() {
      // Organic irregular water stains around eroding chars
      // Uses beginShape + noise-displaced vertices for organic contours
      const stainColor = [140, 180, 210];
      const cellW = (width - CONFIG.grid.marginX * 2) / CONFIG.grid.cols;
      const cellH = (height - CONFIG.grid.marginY * 2) / CONFIG.grid.rows;

      for (let ci = 0; ci < charData.length; ci++) {
        const cd = charData[ci];
        if (cd.wetness < 0.05) continue;

        const intensity = constrain(cd.wetness, 0, 1);

        // Deterministic seed per char
        randomSeed(ci * 137 + 42);

        const count = 1 + Math.floor(intensity); // 1-2 stains per char
        for (let i = 0; i < count; i++) {
          const ox = (random() - 0.5) * cellW * 2.0;
          const oy = (random() - 0.5) * cellH * 2.0;
          const baseR = random(cellW * 0.4, cellW * 0.9); // 1-2 cells size
          const alpha = (54 + random(36)) * intensity; // ~10% lower transparency
          const numVerts = 12 + Math.floor(random(5)); // 12-16 vertices
          const nOff = random(1000); // noise offset for this stain
          // Hue variation: some purplish, some greenish
          const hueShift = random(-1, 1);
          const sr = constrain(stainColor[0] + hueShift * 15, 0, 255);
          const sg = constrain(stainColor[1] - hueShift * 8, 0, 255);
          const sb = constrain(stainColor[2] + (hueShift > 0 ? 10 : -10), 0, 255);

          noStroke();
          fill(sr, sg, sb, alpha);
          beginShape();
          for (let v = 0; v <= numVerts; v++) {
            const angle = (v % numVerts) / numVerts * TWO_PI;
            // Radius varies with noise for organic shape
            const rNoise = noise(nOff + cos(angle) * 1.5 + 10, nOff + sin(angle) * 1.5 + 10);
            const r = baseR * (0.4 + rNoise * 0.8); // 0.4x to 1.2x base radius
            const vx = cd.cx + ox + cos(angle) * r;
            const vy = cd.cy + oy + sin(angle) * r;
            curveVertex(vx, vy);
          }
          // Extra control points for smooth closure
          {
            const angle0 = 0;
            const rN0 = noise(nOff + cos(angle0) * 1.5 + 10, nOff + sin(angle0) * 1.5 + 10);
            const r0 = baseR * (0.4 + rN0 * 0.8);
            curveVertex(cd.cx + ox + cos(angle0) * r0, cd.cy + oy + sin(angle0) * r0);
            const angle1 = TWO_PI / numVerts;
            const rN1 = noise(nOff + cos(angle1) * 1.5 + 10, nOff + sin(angle1) * 1.5 + 10);
            const r1 = baseR * (0.4 + rN1 * 0.8);
            curveVertex(cd.cx + ox + cos(angle1) * r1, cd.cy + oy + sin(angle1) * r1);
          }
          endShape(CLOSE);
        }
      }
      // Restore default seeds
      randomSeed(millis());
      // Do NOT call noiseSeed here — it would change grid noise every frame
    }

    function mousePressed() {
      if (mouseX >= 0 && mouseX <= width && mouseY >= 0 && mouseY <= height) {
        // Reset: clear all drift, curves, and history
        for (let cd of charData) {
          cd.wetness = 0;
          for (let pt of cd.points) {
            pt.drift = 0;
            pt.x = pt.homeX;
            pt.y = pt.homeY;
          }
        }
        curves = [];
        curveHistory = [];
        // Spawn curves at various heights so effect starts quickly
        spawnCurve(undefined, -20);
        spawnCurve(undefined, height * 0.25);
        spawnCurve(undefined, height * 0.5);
        lastSpawnFrame = frameCount;
      }
    }
  </script>
</Base>
