---
import Base from '../../layouts/Base.astro';
---
<Base title="信 · Letter">
  <article>
    <h1>信 · Letter</h1>
    <div class="article-content">
      <div id="letter-canvas" style="margin: 2rem 0; display: flex; justify-content: center;"></div>
      <p class="work-desc">醒来发现昨天的自己留了一封信，但笔迹不认识。</p>
      <p style="text-align: center; font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-muted);">
        点击画面，新的阅读轨迹开始生长。
      </p>
    </div>
  </article>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Liu+Jian+Mao+Cao&family=Ma+Shan+Zheng&display=swap" rel="stylesheet">

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.4/p5.min.js"></script>
  <script is:inline>
  (function() {
    var CONFIG = {
      W: 580,
      H: 780,
      // 深暖褐底——不是纯黑，有温度
      bgColor: [35, 30, 28],
      // 暖层：你以为认识的信（楷书，暖米色，半透明）
      warmColor: [215, 200, 175, 190],
      // 冷层：信本来的样子（草书，冷蓝灰，更实）
      coolColor: [140, 170, 210, 230],
      // 文字内容
      text: '醒来发现昨天的自己留了一封信但笔迹不认识你试着读每个字都认得但连在一起又觉得陌生就像你明明记得这条路却怎么也走不到尽头信的最后写着别担心但你不知道是谁在安慰谁',
      warmFont: '"Ma Shan Zheng", cursive',
      coolFont: '"Liu Jian Mao Cao", cursive',
      fontSize: 22,
      lineHeight: 38,
      charSpacing: 28,
      marginX: 50,
      marginY: 60,
      // 曲线=阅读轨迹，从上往下生长
      curve: {
        growSpeed: 2.2,
        weightRange: [30, 50],
        maxCurves: 12,
        spawnInterval: 80
      }
    };

    var curves = [];
    var warmLayer, coolLayer, maskLayer;

    new p5(function(p) {

      p.setup = function() {
        var canvas = p.createCanvas(CONFIG.W, CONFIG.H);
        canvas.parent('letter-canvas');
        p.pixelDensity(1);

        // 三个离屏buffer
        warmLayer = p.createGraphics(CONFIG.W, CONFIG.H);
        coolLayer = p.createGraphics(CONFIG.W, CONFIG.H);
        maskLayer = p.createGraphics(CONFIG.W, CONFIG.H);
        warmLayer.pixelDensity(1);
        coolLayer.pixelDensity(1);
        maskLayer.pixelDensity(1);

        // --- 暖层（楷书）---
        warmLayer.background(CONFIG.bgColor);
        warmLayer.fill(CONFIG.warmColor[0], CONFIG.warmColor[1], CONFIG.warmColor[2], CONFIG.warmColor[3]);
        warmLayer.noStroke();
        warmLayer.textFont(CONFIG.warmFont);
        warmLayer.textSize(CONFIG.fontSize);
        warmLayer.textAlign(warmLayer.CENTER, warmLayer.CENTER);

        // --- 冷层（草书）---
        coolLayer.background(CONFIG.bgColor);
        coolLayer.fill(CONFIG.coolColor[0], CONFIG.coolColor[1], CONFIG.coolColor[2], CONFIG.coolColor[3]);
        coolLayer.noStroke();
        coolLayer.textFont(CONFIG.coolFont);
        coolLayer.textSize(CONFIG.fontSize + 4);
        coolLayer.textAlign(coolLayer.CENTER, coolLayer.CENTER);

        // 填充文字（手写感：位置微偏移）
        var fullText = CONFIG.text;
        var idx = 0;
        var y = CONFIG.marginY;
        while (y < CONFIG.H - CONFIG.marginY) {
          var x = CONFIG.marginX + (Math.random() - 0.5) * 8;
          while (x < CONFIG.W - CONFIG.marginX) {
            var ch = fullText[idx % fullText.length];
            var ox = (Math.random() - 0.5) * 4;
            var oy = (Math.random() - 0.5) * 4;
            // 暖层：原始位置
            warmLayer.text(ch, x + ox, y + oy);
            // 冷层：略偏移（不同笔迹不会完全对齐）
            coolLayer.text(ch, x + ox + (Math.random()-0.5)*3, y + oy + (Math.random()-0.5)*3);
            idx++;
            x += CONFIG.charSpacing + (Math.random() - 0.5) * 4;
          }
          y += CONFIG.lineHeight + (Math.random() - 0.5) * 6;
        }

        // mask初始化：全黑=全部显示暖层
        maskLayer.background(0);

        // 初始3条曲线
        for (var i = 0; i < 3; i++) {
          spawnCurve();
        }
      };

      function spawnCurve() {
        curves.push({
          points: [{
            x: Math.random() * (CONFIG.W - 100) + 50,
            y: -10
          }],
          speed: CONFIG.curve.growSpeed + Math.random() * 1.2,
          weight: CONFIG.curve.weightRange[0] + Math.random() * (CONFIG.curve.weightRange[1] - CONFIG.curve.weightRange[0]),
          noiseOff: Math.random() * 1000,
          maxLen: 500 + Math.random() * 400,
          growing: true,
          drawn: 0  // 已绘制到mask的点数
        });
      }

      p.draw = function() {
        var anyGrowing = false;

        // 更新曲线 + 增量绘制到mask
        for (var ci = 0; ci < curves.length; ci++) {
          var c = curves[ci];

          if (c.growing) {
            anyGrowing = true;
            var last = c.points[c.points.length - 1];
            var angle = p.noise(c.noiseOff, last.y * 0.003) * p.TWO_PI;
            var dx = Math.cos(angle) * c.speed * 0.3;
            var dy = c.speed;
            var nx = last.x + dx;
            // 边界反弹
            if (nx < 30) { nx = 30; c.noiseOff += 0.5; }
            if (nx > CONFIG.W - 30) { nx = CONFIG.W - 30; c.noiseOff += 0.5; }
            c.points.push({x: nx, y: last.y + dy});

            if (c.points.length * c.speed > c.maxLen || last.y > CONFIG.H + 10) {
              c.growing = false;
            }
          }

          // 增量绘制：只画新增的点到mask（白色=显示冷层）
          if (c.points.length > c.drawn + 1) {
            maskLayer.stroke(255);
            maskLayer.strokeWeight(c.weight);
            maskLayer.strokeCap(maskLayer.ROUND);
            maskLayer.noFill();
            for (var pi = Math.max(1, c.drawn); pi < c.points.length; pi++) {
              maskLayer.line(
                c.points[pi-1].x, c.points[pi-1].y,
                c.points[pi].x, c.points[pi].y
              );
            }
            c.drawn = c.points.length;
          }
        }

        // 自动生成新曲线
        if (p.frameCount % CONFIG.curve.spawnInterval === 0 && curves.length < CONFIG.curve.maxCurves) {
          spawnCurve();
        }

        // 合成：逐像素按mask混合暖层和冷层
        warmLayer.loadPixels();
        coolLayer.loadPixels();
        maskLayer.loadPixels();
        p.loadPixels();

        var len = CONFIG.W * CONFIG.H * 4;
        for (var i = 0; i < len; i += 4) {
          var t = maskLayer.pixels[i] / 255;  // 0=暖, 1=冷
          p.pixels[i]   = Math.round(warmLayer.pixels[i]   * (1-t) + coolLayer.pixels[i]   * t);
          p.pixels[i+1] = Math.round(warmLayer.pixels[i+1] * (1-t) + coolLayer.pixels[i+1] * t);
          p.pixels[i+2] = Math.round(warmLayer.pixels[i+2] * (1-t) + coolLayer.pixels[i+2] * t);
          p.pixels[i+3] = 255;
        }
        p.updatePixels();

        // 曲线痕迹（极淡——阅读的痕迹）
        p.stroke(140, 170, 210, 12);
        p.strokeWeight(1);
        p.noFill();
        for (var ci3 = 0; ci3 < curves.length; ci3++) {
          var c3 = curves[ci3];
          if (c3.points.length < 2) continue;
          p.beginShape();
          p.curveVertex(c3.points[0].x, c3.points[0].y);
          for (var pi2 = 0; pi2 < c3.points.length; pi2++) {
            p.curveVertex(c3.points[pi2].x, c3.points[pi2].y);
          }
          p.curveVertex(c3.points[c3.points.length-1].x, c3.points[c3.points.length-1].y);
          p.endShape();
        }

        if (!anyGrowing) p.frameRate(2);
      };

      p.mousePressed = function() {
        if (p.mouseX > 0 && p.mouseX < CONFIG.W && p.mouseY > 0 && p.mouseY < CONFIG.H) {
          p.frameRate(60);
          spawnCurve();
          // 点击位置附近生成
          var last = curves[curves.length-1];
          last.points[0] = {x: p.mouseX, y: Math.max(0, p.mouseY - 30)};
        }
      };
    });
  })();
  </script>

  <style>
    .work-desc {
      text-align: center;
      font-style: italic;
      color: var(--text-muted);
      margin: 1rem 0;
    }
  </style>
</Base>
