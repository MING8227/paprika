---
import Base from '../../layouts/Base.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<Base title="Gallery">
  <h1>Gallery</h1>
  <p>用代码画的东西。Generative art，算法驱动，每次运行都不一样。</p>

  <hr />

  <div class="gallery-grid">
    <div class="gallery-item">
      <a href={`${base}gallery/letter`} class="gallery-link">
        <div class="gallery-preview">
          <iframe src={`${base}gallery/letter-embed`} scrolling="no" loading="lazy"></iframe>
          <div class="gallery-overlay"></div>
        </div>
        <div class="gallery-info">
          <span class="gallery-date">2026.03.19</span>
          <span class="gallery-title">信 · Letter</span>
        </div>
      </a>
    </div>

    <div class="gallery-item">
      <a href={`${base}gallery/complement`} class="gallery-link">
        <div class="gallery-preview">
          <iframe src={`${base}gallery/complement-embed`} scrolling="no" loading="lazy"></iframe>
          <div class="gallery-overlay"></div>
        </div>
        <div class="gallery-info">
          <span class="gallery-date">2026.03.16</span>
          <span class="gallery-title">互补 · Complement</span>
        </div>
      </a>
    </div>

    <div class="gallery-item">
      <a href={`${base}gallery/root`} class="gallery-link">
        <div class="gallery-preview">
          <iframe src={`${base}gallery/root-embed`} scrolling="no" loading="lazy"></iframe>
          <div class="gallery-overlay"></div>
        </div>
        <div class="gallery-info">
          <span class="gallery-date">2026.03.12</span>
          <span class="gallery-title">根 · Root</span>
        </div>
      </a>
    </div>

    <div class="gallery-item">
      <a href={`${base}gallery/relay`} class="gallery-link">
        <div class="gallery-preview">
          <iframe src={`${base}gallery/relay-embed`} scrolling="no" loading="lazy"></iframe>
          <div class="gallery-overlay"></div>
        </div>
        <div class="gallery-info">
          <span class="gallery-date">2026.03.11</span>
          <span class="gallery-title">接力 · Relay</span>
        </div>
      </a>
    </div>
  </div>
</Base>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 2rem;
  }

  .gallery-item {
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .gallery-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .gallery-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .gallery-preview {
    position: relative;
    width: 100%;
    height: 420px;
    overflow: hidden;
    background: #1a1a18;
    border-radius: 8px 8px 0 0;
  }

  .gallery-preview iframe {
    width: 100%;
    height: 100%;
    border: none;
    pointer-events: none;
  }

  .gallery-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    cursor: pointer;
  }

  .gallery-info {
    padding: 0.8rem 1rem;
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
  }

  .gallery-date {
    font-family: var(--font-mono, monospace);
    font-size: 0.72rem;
    color: var(--text-muted, #999);
  }

  .gallery-title {
    font-size: 1rem;
    font-weight: 500;
  }

  @media (min-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .gallery-preview {
      height: 320px;
    }
  }
</style>
