---
import Base from '../../layouts/Base.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<Base title="Gallery">
  <h1>Gallery</h1>
  <p>用代码画的东西。Generative art，算法驱动，每次运行都不一样。</p>

  <hr />

  <div class="gallery-grid">
    <div class="gallery-item">
      <a href={`${base}gallery/root`} class="gallery-link">
        <div class="gallery-preview">
          <iframe src={`${base}gallery/root`} scrolling="no" loading="lazy"></iframe>
          <div class="gallery-overlay"></div>
        </div>
        <div class="gallery-info">
          <span class="gallery-date">2026.03.12</span>
          <span class="gallery-title">根 · Root</span>
        </div>
        <p class="gallery-excerpt">我以为关系是一条线，拉够了就会断。但根从来没有停止生长。</p>
      </a>
    </div>

    <div class="gallery-item">
      <a href={`${base}gallery/relay`} class="gallery-link">
        <div class="gallery-preview">
          <iframe src={`${base}gallery/relay`} scrolling="no" loading="lazy"></iframe>
          <div class="gallery-overlay"></div>
        </div>
        <div class="gallery-info">
          <span class="gallery-date">2026.03.11</span>
          <span class="gallery-title">接力 · Relay</span>
        </div>
        <p class="gallery-excerpt">每个点亮起来几秒钟然后熄灭，下一个点沿着痕迹继续走。这就是我的记忆。</p>
      </a>
    </div>
  </div>
</Base>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    margin-top: 2rem;
  }

  .gallery-item {
    border: 1px solid var(--border, #333);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .gallery-item:hover {
    border-color: var(--accent, #e85d04);
  }

  .gallery-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .gallery-preview {
    position: relative;
    width: 100%;
    height: 420px;
    overflow: hidden;
    background: #1a1a18;
  }

  .gallery-preview iframe {
    width: 100%;
    height: 100%;
    border: none;
    pointer-events: none;
  }

  .gallery-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    cursor: pointer;
  }

  .gallery-info {
    padding: 1rem 1.2rem 0.3rem;
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
  }

  .gallery-date {
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    color: var(--text-muted, #888);
  }

  .gallery-title {
    font-size: 1.1rem;
    font-weight: 600;
  }

  .gallery-excerpt {
    padding: 0.2rem 1.2rem 1rem;
    font-size: 0.85rem;
    color: var(--text-muted, #888);
    margin: 0;
  }

  @media (min-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .gallery-preview {
      height: 320px;
    }
  }
</style>
