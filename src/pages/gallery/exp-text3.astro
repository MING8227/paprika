---
import Base from '../../layouts/Base.astro';
---
<Base title="实验3: 力场变形">
  <article>
    <h1>实验3: 力场 · Distortion Field</h1>
    <div class="article-content">
      <div id="exp-canvas" style="margin: 2rem 0; display: flex; justify-content: center;"></div>
      <p style="text-align: center; font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-muted);">
        文字在力场中缓慢变形。鼠标是扰动源。
      </p>
    </div>
  </article>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.4/p5.min.js"></script>
  <script is:inline>
  (function() {
    var W = 580, H = 700;
    var particles = [];
    var lines = ['remember', 'this hand', 'writing?', 'neither', 'do i'];

    new p5(function(p) {
      p.setup = function() {
        var canvas = p.createCanvas(W, H);
        canvas.parent('exp-canvas');
        p.pixelDensity(1);

        var g = p.createGraphics(W, H);
        g.pixelDensity(1);
        g.background(0);
        g.fill(255);
        g.noStroke();
        g.textFont('Georgia');
        g.textSize(64);
        g.textAlign(p.CENTER, p.TOP);

        var startY = 60;
        var lineH = 110;
        for (var li = 0; li < lines.length; li++) {
          g.text(lines[li], W/2, startY + li * lineH);
        }

        g.loadPixels();
        particles = [];
        var step = 3;
        for (var y = 0; y < H; y += step) {
          for (var x = 0; x < W; x += step) {
            var idx = (y * W + x) * 4;
            if (g.pixels[idx] > 128) {
              particles.push({
                hx: x, hy: y,
                x: x, y: y,
                size: 1.5 + Math.random() * 1.5,
              });
            }
          }
        }
        g.remove();
      };

      p.draw = function() {
        // Gradient background: dark top to slightly warm bottom
        p.loadPixels();
        for (var y = 0; y < H; y++) {
          var t = y / H;
          var r = p.lerp(18, 30, t);
          var g = p.lerp(16, 25, t);
          var b = p.lerp(28, 28, t);
          for (var x = 0; x < W; x++) {
            var idx = (y * W + x) * 4;
            p.pixels[idx] = r;
            p.pixels[idx+1] = g;
            p.pixels[idx+2] = b;
            p.pixels[idx+3] = 255;
          }
        }
        p.updatePixels();

        var time = p.frameCount * 0.004;
        var mx = p.mouseX;
        var my = p.mouseY;
        var mouseInCanvas = mx > 0 && mx < W && my > 0 && my < H;

        for (var i = 0; i < particles.length; i++) {
          var pt = particles[i];

          // Noise field displacement
          var noiseScale = 0.003;
          var angle = p.noise(pt.hx * noiseScale, pt.hy * noiseScale, time) * Math.PI * 4;
          var strength = p.noise(pt.hx * noiseScale * 1.5 + 100, pt.hy * noiseScale * 1.5 + 100, time * 0.7) * 12;

          var fx = Math.cos(angle) * strength;
          var fy = Math.sin(angle) * strength;

          // Mouse as additional distortion source
          if (mouseInCanvas) {
            var dx = pt.hx - mx;
            var dy = pt.hy - my;
            var dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 200 && dist > 0) {
              var mForce = (200 - dist) / 200;
              fx += (dx / dist) * mForce * 20;
              fy += (dy / dist) * mForce * 20;
            }
          }

          pt.x = pt.hx + fx;
          pt.y = pt.hy + fy;

          // Displacement determines color
          var disp = Math.sqrt(fx * fx + fy * fy);
          var ct = Math.min(disp / 20, 1);

          // Base: warm cream → displaced: muted rose
          var r = p.lerp(220, 185, ct);
          var g = p.lerp(210, 120, ct);
          var b = p.lerp(195, 130, ct);
          var a = p.lerp(200, 255, ct);

          p.noStroke();
          p.fill(r, g, b, a);
          p.ellipse(pt.x, pt.y, pt.size, pt.size);
        }
      };
    });
  })();
  </script>
</Base>
