  function hexToRgb(hex) {
    const r = parseInt(hex.slice(1,3), 16);
    const g = parseInt(hex.slice(3,5), 16);
    const b = parseInt(hex.slice(5,7), 16);
    return [r, g, b];
  }

  function polarToXY(node, w, h) {
    const rBase = Math.min(w, h);
    const r = RINGS[node.ring] * rBase;
    const a = node.angle * Math.PI / 180;
    return {
      x: CX * w + r * Math.cos(-a),
      y: CY * h + r * Math.sin(-a)
    };
  }

  function buildBubbles(p) {
    bubbles = [];
    NODES.forEach((node, i) => {
      const ringSizes = [56, 36, 22, 16, 17, 17];
      const baseR = ringSizes[node.ring] || 18;
      const home = polarToXY(node, p.width, p.height);
      bubbles.push({
        x: home.x + p.random(-10, 10),
        y: home.y + p.random(-10, 10),
        homeX: home.x,
        homeY: home.y,
        spring: node.spring,
        vx: p.random(-0.1, 0.1),
        vy: p.random(-0.1, 0.1),
        r: baseR,
        node: node,
        col: hexToRgb(COLORS[node.cat])
      });
    });
  }

  function switchVersion(ver) {
    if (!VERSIONS[ver]) return;
    currentVersion = ver;
    NODES = VERSIONS[ver].nodes;
    EDGES = VERSIONS[ver].edges;
    CHAINS = VERSIONS[ver].chains;
    RING_INFO = VERSIONS[ver].ringInfo;
    buildNodeChains();
    buildConnCount();
