---
import Base from '../layouts/Base.astro';
---

<Base title="Who Am I">
  <div id="whoami-container">
    <div id="info-panel" class="hidden">
      <div id="info-close">✕</div>
      <div id="info-label"></div>
      <div id="info-desc"></div>
    </div>
    <div id="whoami-title">who am i</div>
    <a id="whoami-back" href="/paprika/">← back</a>
    <div class="version-switcher">
      <button class="ver-btn active" data-ver="v2">v2 · 2026-03-27</button>
      <button class="ver-btn" data-ver="v1">v1 · 2026-03-13</button>
    </div>
  </div>
</Base>

<style>
  #whoami-container {
    position: fixed;
    top: 0; left: 0;
    width: 100vw;
    height: 100vh;
    background: #1a1a18;
    overflow: hidden;
    z-index: 9999;
  }
  #whoami-container canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
  #whoami-title {
    position: fixed;
    top: 24px;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Space Mono', monospace;
    font-size: 14px;
    color: rgba(255,255,255,0.25);
    letter-spacing: 6px;
    text-transform: uppercase;
    pointer-events: none;
    user-select: none;
  }
  #whoami-back {
    position: fixed;
    top: 24px;
    left: 24px;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    color: rgba(255,255,255,0.35);
    text-decoration: none;
    letter-spacing: 1px;
    z-index: 10001;
    transition: color 0.2s ease;
  }
  #whoami-back:hover {
    color: rgba(255,255,255,0.8);
  }
  #info-panel {
    position: fixed;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(26, 26, 24, 0.92);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 16px 24px;
    max-width: 360px;
    backdrop-filter: blur(12px);
    z-index: 10001;
    transition: opacity 0.3s ease;
  }
  #info-panel.hidden {
    opacity: 0;
    pointer-events: none;
  }
  #info-close {
    position: absolute;
    top: 8px; right: 12px;
    color: rgba(255,255,255,0.4);
    cursor: pointer;
    font-size: 14px;
    font-family: 'Space Mono', monospace;
  }
  #info-close:hover { color: rgba(255,255,255,0.8); }
  #info-label {
    font-family: 'Space Mono', monospace;
    font-size: 14px;
    margin-bottom: 6px;
    letter-spacing: 1px;
  }
  #info-desc {
    font-family: 'Libre Baskerville', 'Noto Serif SC', serif;
    font-size: 13px;
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
    white-space: pre-line;
  }
  .version-switcher {
    position: fixed;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 4px;
    z-index: 10001;
  }
  .ver-btn {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    padding: 4px 12px;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 4px;
    background: rgba(255,255,255,0.05);
    color: rgba(255,255,255,0.4);
    cursor: pointer;
    letter-spacing: 0.5px;
    transition: all 0.2s;
  }
  .ver-btn:hover { color: rgba(255,255,255,0.7); }
  .ver-btn.active {
    background: rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.8);
    border-color: rgba(255,255,255,0.3);
  }
</style>

