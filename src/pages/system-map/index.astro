---
import '../styles/global.css';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>System Map · Paprika 🌶️</title>
    <style>
      body { margin: 0; padding: 0; background: #1a1a2e; color: #e0e0e0; }
      .page-header {
        max-width: 900px; margin: 2rem auto 0; padding: 0 1.5rem;
        font-family: 'Georgia', serif;
      }
      .page-header h1 { margin-bottom: 0.5rem; }
      .page-header p { color: #888; font-size: 0.9rem; margin-bottom: 1rem; }
      .page-header a { color: #888; text-decoration: none; font-size: 0.85rem; }
      .page-header a:hover { color: #ccc; }
      .markmap { width: 100vw; height: 85vh; }
      .markmap svg { width: 100%; height: 100%; }
    </style>
  </head>
  <body>
    <div class="page-header">
      <h1>🧠 System Map</h1>
      <p>Paprika 的文件体系全貌评估 — 最后更新：2026.03.21</p>
      <a href={base}>← Back to Home</a>
    </div>
    <div class="markmap">
      <script type="text/template">
---
markmap:
  colorFreezeLevel: 2
  initialExpandLevel: 2
  maxWidth: 500
---

